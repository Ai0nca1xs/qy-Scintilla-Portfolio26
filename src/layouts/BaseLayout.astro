---
// 全站共用的頁面外殼：<html> 骨架 + Header + Footer + 游標 + 平滑滾動 + 進度細線。
// 頁面只需要提供標題、描述和內容本身。
import BaseHead from '@/components/BaseHead.astro';
import Cursor from '@/components/Cursor.astro';
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import ScrollProgress from '@/components/ScrollProgress.astro';
import SmoothScroll from '@/components/SmoothScroll.astro';
import { SITE_DESCRIPTION } from '@/consts';
import { getLangFromUrl } from '@/i18n/utils';

interface Props {
	title: string;
	description?: string;
}

const { title, description = SITE_DESCRIPTION } = Astro.props;
const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang === 'FR' ? 'fr' : 'en'}>
	<head>
		<script is:inline>
			// 標記 JS 可用：滾動顯影的初始隱藏態只在此時生效（漸進增強）
			document.documentElement.classList.add('js');
		</script>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Cursor />
		<ScrollProgress />
		<Header />
		<main class="layout-container">
			<slot />
		</main>
		<Footer />
		<SmoothScroll />

		<script>
			import { initTextMotion, initTypeShuffle, initSettle } from '@/scripts/text-motion';

			// 文字載入動效（reveal 顯影系統已退役，統一由 text-motion 承擔）
			document.addEventListener('astro:page-load', () => {
				initTextMotion(); // 逐詞滾動顯現（data-text-motion）
				initTypeShuffle(); // 字符翻牌解碼（data-type-shuffle）
				initSettle(); // 沉澱式入場（data-settle）
			});

			// 圖片保護（威懾層）：作品圖上禁用右鍵選單，配合 CSS 禁拖拽。
			// 只攔圖片不攔全頁，不影響正常瀏覽；無法防止截圖。
			document.addEventListener('contextmenu', (e) => {
				if (e.target instanceof HTMLImageElement) e.preventDefault();
			});
		</script>
	</body>
</html>
