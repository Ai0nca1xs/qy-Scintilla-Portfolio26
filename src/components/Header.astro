---
import { getLangFromUrl, getLangSwitchUrl, localizePath, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header class="site-header">
	<div class="header-inner">
		<div class="nav-left">
			<a href={localizePath(lang, '/')} class="site-mark">{t.site.tagline}</a>
		</div>

		<nav class="nav-right">
			<div class="lang-switch">
				<a
					href={lang === 'EN' ? '#' : getLangSwitchUrl(Astro.url, 'EN')}
					class={lang === 'EN' ? 'active' : ''}>EN</a
				>
				<span class="separator">/</span>
				<a
					href={lang === 'FR' ? '#' : getLangSwitchUrl(Astro.url, 'FR')}
					class={lang === 'FR' ? 'active' : ''}>FR</a
				>
			</div>

			<ul class="nav-links">
				<li><a href={localizePath(lang, '/')}>{t.nav.home}</a></li>
				<li><a href={localizePath(lang, '/project')}>{t.nav.project}</a></li>
				<li><a href={localizePath(lang, '/gallery')}>{t.nav.gallery}</a></li>
				<li><a href={localizePath(lang, '/contact')}>{t.nav.contact}</a></li>
			</ul>
		</nav>
	</div>
</header>

<style>
	/* 1. 吸頂容器：半透明冷白 + 毛玻璃，滾動時內容從其下方「沉澱」離場 */
	.site-header {
		position: sticky;
		top: 0;
		z-index: 500;
		background: rgba(248, 249, 250, 0.78);
		-webkit-backdrop-filter: blur(10px);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--color-line);
	}

	.header-inner {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		max-width: var(--container-max-width);
		margin: 0 auto;
		padding: 1rem var(--gutter);
	}

	/* 2. 文字基礎設定：等寬 metadata 氣質 */
	.site-header a,
	.site-header span {
		font-family: var(--font-mono);
		font-size: 10px;
		font-weight: 400;
		letter-spacing: 0.12em;
		margin: 0;
		line-height: 2;
		text-transform: uppercase;
	}

	.site-mark {
		opacity: 0.85;
	}

	/* 3. 右側導覽群組佈局 */
	.nav-right {
		display: flex;
		align-items: baseline;
		gap: 2.3rem;
	}

	/* 4. 語系切換 */
	.lang-switch {
		display: flex;
		align-items: baseline;
		gap: 0.25rem;
	}
	.lang-switch .separator {
		opacity: 0.3;
	}
	.lang-switch a {
		opacity: 0.5;
		transition: opacity 0.2s ease;
	}
	.lang-switch a.active,
	.lang-switch a:hover {
		opacity: 1;
	}

	/* 5. 導覽列與氧化互動邏輯 */
	.nav-links {
		display: flex;
		list-style: none;
		margin: 0;
		padding: 0;
		gap: 1.5rem;
	}

	.nav-links a {
		display: inline-block; /* 必須設定為 inline-block 才能讓 transform 縮放生效 */
		opacity: 0.6;
		transition: all 0.4s var(--ease-oxide);
		transform-origin: center;
	}

	/* 觸發條件 A：游標懸停在整個導覽列上時，所有連結模糊、變暗、微縮 */
	.nav-links:hover a {
		filter: blur(1px);
		opacity: 0.2;
		transform: scale(0.95);
	}

	/* 觸發條件 B：被直接懸停的連結解除限制，點亮為洋紅 */
	.nav-links a:hover {
		filter: blur(0);
		opacity: 1;
		transform: scale(1.12);
		color: var(--color-magenta);
	}

	/* 手機端：站名縮短空間，導覽保持可點 */
	@media (max-width: 640px) {
		.header-inner {
			flex-wrap: wrap;
			gap: 0.3rem;
		}
		.nav-right {
			gap: 1.4rem;
		}
	}
</style>
