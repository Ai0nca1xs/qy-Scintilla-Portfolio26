---
import { getLangFromUrl, getLangSwitchUrl, localizePath, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// 判斷當前所在的區塊，點亮對應的導覽按鈕
const path = Astro.url.pathname;
const section = path.includes('/project')
	? 'project'
	: path.includes('/gallery')
		? 'gallery'
		: path.includes('/contact')
			? 'contact'
			: 'home';

const navItems = [
	{ key: 'home', label: t.nav.home, href: localizePath(lang, '/') },
	{ key: 'project', label: t.nav.project, href: localizePath(lang, '/project') },
	{ key: 'gallery', label: t.nav.gallery, href: localizePath(lang, '/gallery') },
	{ key: 'contact', label: t.nav.contact, href: localizePath(lang, '/contact') },
];
---

<header class="site-header">
	<div class="header-inner">
		<div class="nav-left">
			{/* 左上說明文字：SCINTILLA 全大寫，其餘首字母大寫；12px 左對齊兩行 */}
			<a href={localizePath(lang, '/')} class="site-mark">
				<span class="mark-line">SCINTILLA — Specimen archive</span>
				<span class="mark-line mark-sub">{t.site.tagline}</span>
			</a>
		</div>

		<nav class="nav-right">
			<div class="lang-switch">
				<a
					href={lang === 'EN' ? '#' : getLangSwitchUrl(Astro.url, 'EN')}
					class={lang === 'EN' ? 'active' : ''}>EN</a
				>
				<span class="separator">/</span>
				<a
					href={lang === 'FR' ? '#' : getLangSwitchUrl(Astro.url, 'FR')}
					class={lang === 'FR' ? 'active' : ''}>FR</a
				>
			</div>

			<ul class="nav-links">
				{
					navItems.map((item) => (
						<li>
							<a
								class:list={['nav-btn', { current: section === item.key }]}
								href={item.href}
								aria-current={section === item.key ? 'page' : undefined}
							>
								<span class="btn-label">{item.label}</span>
							</a>
						</li>
					))
				}
			</ul>
		</nav>
	</div>
</header>

<style>
	/* 1. 吸頂容器：無背景——文字與按鈕直接浮在頁面之上 */
	.site-header {
		position: sticky;
		top: 0;
		z-index: 500;
	}

	.header-inner {
		display: flex;
		justify-content: space-between;
		align-items: center;
		max-width: var(--container-max-width);
		margin: 0 auto;
		padding: 0.75rem var(--gutter) 0.6rem;
	}

	/* 2. 文字基礎設定 */
	.site-header a,
	.site-header span {
		font-size: 12px;
		font-weight: 400;
		letter-spacing: 0.1em;
		line-height: 1.4;
		margin: 0;
	}

	/* 左上兩行說明：12px 左對齊 */
	.site-mark {
		display: flex;
		flex-direction: column;
		text-align: left;
		opacity: 0.9;
	}
	.mark-sub {
		color: var(--text-secondary);
	}

	/* 3. 右側導覽群組佈局 */
	.nav-right {
		display: flex;
		align-items: center;
		gap: 2rem;
	}

	/* 4. 語系切換 */
	.lang-switch {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}
	.lang-switch .separator {
		opacity: 0.3;
	}
	.lang-switch a {
		opacity: 0.5;
		transition: opacity 0.2s ease;
	}
	.lang-switch a.active,
	.lang-switch a:hover {
		opacity: 1;
	}

	/* 5. 導覽按鈕：粉光徑向漸變 + 柔光暈（直角、等寬字體）*/
	.nav-links {
		display: flex;
		align-items: center;
		list-style: none;
		margin: 0;
		padding: 0;
		gap: 12px;
	}

	.nav-links li {
		display: flex;
	}

	/* 鵝蛋形柔光：按鈕本體無框無底，漸變畫在 ::before 橢圓上並模糊邊緣——
	   看起來是一團蛋形的光暈，而非盒子。文字全大寫。 */
	.nav-btn {
		--btn-anim: 0.55s;
		position: relative;
		height: var(--btn-height);
		width: 100px;
		display: inline-flex;
		justify-content: center;
		align-items: center;
		cursor: pointer;
		font-family: var(--font-mono);
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: #403096;
		border: none;
		background: none;
	}

	.nav-btn::before {
		content: '';
		position: absolute;
		inset: -4px -6px;
		border-radius: 50%;
		background: radial-gradient(closest-side, #ffbad5 30%, rgba(255, 255, 255, 0) 100%);
		filter: blur(5px);
		transition:
			opacity 0.5s ease,
			background 0.3s ease,
			box-shadow 0.5s ease;
	}

	/* 懸浮：光暈變淡 */
	.nav-btn:hover::before {
		opacity: 0.45;
	}

	/* 點擊 / 當前選中：顏色變化 + 邊緣向外擴散 */
	.nav-btn:active::before,
	.nav-btn.current::before {
		opacity: 1;
		background: radial-gradient(closest-side, #ff9dbe 24%, rgba(255, 227, 238, 0) 100%);
		box-shadow: 0 0 26px 10px rgba(255, 0, 72, 0.22);
	}
	.nav-btn:active,
	.nav-btn.current {
		color: var(--color-accent);
	}

	.btn-label {
		position: relative;
		z-index: 1;
	}

	/* 6. 懸浮字符亂碼載入動畫（chitchat，加速版）：
	   動畫期間真實文字隱形，::before 播放亂碼序列，結束顯回文字 */
	.btn-label {
		position: relative;
		white-space: nowrap;
	}

	.btn-label::before {
		content: '';
		position: absolute;
		left: 0;
		top: 50%;
		transform: translateY(-50%);
		color: inherit;
	}

	.nav-btn:hover .btn-label {
		animation: label-conceal var(--btn-anim) linear both;
	}
	.nav-btn:hover .btn-label::before {
		animation: chitchat var(--btn-anim) linear both;
	}

	@keyframes label-conceal {
		0%,
		94% {
			color: transparent;
		}
		100% {
			color: currentColor;
		}
	}

	@keyframes chitchat {
		0% {
			content: '#';
		}
		5% {
			content: '.';
		}
		10% {
			content: '^{';
		}
		15% {
			content: '-!';
		}
		20% {
			content: '#$_';
		}
		25% {
			content: '№:0';
		}
		30% {
			content: '#{+.';
		}
		35% {
			content: '@}-?';
		}
		40% {
			content: '?{4@%';
		}
		45% {
			content: '=.,^!';
		}
		50% {
			content: '?2@%';
		}
		55% {
			content: '\\;1}]';
		}
		60% {
			content: '?{%:%';
		}
		65% {
			content: '|{f[4';
		}
		70% {
			content: '{4%0%';
		}
		75% {
			content: "'1_0<";
		}
		80% {
			content: '{0%';
		}
		85% {
			content: "]>'";
		}
		90% {
			content: '4';
		}
		95% {
			content: '2';
		}
		100% {
			content: '';
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.nav-btn:hover .btn-label,
		.nav-btn:hover .btn-label::before {
			animation: none;
		}
	}

	@media (max-width: 720px) {
		.header-inner {
			flex-wrap: wrap;
			gap: 8px;
			padding-top: 8px;
			padding-bottom: 8px;
		}
		.nav-right {
			gap: 16px;
		}
		.nav-btn {
			width: auto;
			padding: 0 12px;
		}
	}
</style>
