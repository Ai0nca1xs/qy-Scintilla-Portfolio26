---
import { getLangFromUrl, getLangSwitchUrl, localizePath, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// 判斷當前所在的區塊，點亮對應的導覽膠囊
const path = Astro.url.pathname;
const section = path.includes('/project')
	? 'project'
	: path.includes('/gallery')
		? 'gallery'
		: path.includes('/contact')
			? 'contact'
			: 'home';

const navItems = [
	{ key: 'home', label: t.nav.home, href: localizePath(lang, '/') },
	{ key: 'project', label: t.nav.project, href: localizePath(lang, '/project') },
	{ key: 'gallery', label: t.nav.gallery, href: localizePath(lang, '/gallery') },
	{ key: 'contact', label: t.nav.contact, href: localizePath(lang, '/contact') },
];
---

<header class="site-header">
	<div class="header-inner">
		<div class="nav-left">
			<a href={localizePath(lang, '/')} class="site-mark">{t.site.tagline}</a>
		</div>

		<nav class="nav-right">
			<div class="lang-switch">
				<a
					href={lang === 'EN' ? '#' : getLangSwitchUrl(Astro.url, 'EN')}
					class={lang === 'EN' ? 'active' : ''}>EN</a
				>
				<span class="separator">/</span>
				<a
					href={lang === 'FR' ? '#' : getLangSwitchUrl(Astro.url, 'FR')}
					class={lang === 'FR' ? 'active' : ''}>FR</a
				>
			</div>

			<ul class="nav-links">
				{
					navItems.map((item) => (
						<li>
							<a
								class:list={['nav-pill', { current: section === item.key }]}
								href={item.href}
								aria-current={section === item.key ? 'page' : undefined}
							>
								<span class="pill-roll">
									<span class="pill-face front">{item.label}</span>
									<span class="pill-face back" aria-hidden="true">
										{item.label}
									</span>
								</span>
							</a>
						</li>
					))
				}
			</ul>
		</nav>
	</div>
</header>

<style>
	/* 1. 吸頂容器：半透明冷白 + 毛玻璃 */
	.site-header {
		position: sticky;
		top: 0;
		z-index: 500;
		background: rgba(248, 249, 250, 0.78);
		-webkit-backdrop-filter: blur(10px);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--color-line);
	}

	.header-inner {
		display: flex;
		justify-content: space-between;
		align-items: center;
		max-width: var(--container-max-width);
		margin: 0 auto;
		padding: 0.35rem var(--gutter);
	}

	/* 2. 文字基礎設定 */
	.site-header a,
	.site-header span {
		font-size: 11px;
		font-weight: 400;
		letter-spacing: 0.1em;
		margin: 0;
		text-transform: uppercase;
	}

	.site-mark {
		opacity: 0.85;
	}

	/* 3. 右側導覽群組佈局 */
	.nav-right {
		display: flex;
		align-items: center;
		gap: 2rem;
	}

	/* 4. 語系切換 */
	.lang-switch {
		display: flex;
		align-items: baseline;
		gap: 0.25rem;
	}
	.lang-switch .separator {
		opacity: 0.3;
	}
	.lang-switch a {
		opacity: 0.5;
		transition: opacity 0.2s ease;
	}
	.lang-switch a.active,
	.lang-switch a:hover {
		opacity: 1;
	}

	/* 5. 導覽膠囊：純色圓角塊 + 骰子滾動翻面 */
	.nav-links {
		display: flex;
		list-style: none;
		margin: 0;
		padding: 0;
		gap: 0.5rem;
	}

	.nav-pill {
		--half: 9.5px; /* 膠囊高度的一半，決定 3D 滾動的軸距（須與 pill-face 高度匹配）*/
		display: block;
		perspective: 600px;
	}

	.nav-pill:hover {
		opacity: 1;
	}

	.pill-roll {
		position: relative;
		display: block;
		transform-style: preserve-3d;
		transition: transform 0.55s var(--ease-spring);
	}

	.pill-face {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0.28rem 0.85rem;
		border-radius: 999px;
		background: #e9ebee;
		color: var(--color-ink);
		white-space: nowrap;
		backface-visibility: hidden;
	}

	.front {
		transform: translateZ(var(--half));
	}

	/* 翻面：洋紅純色 */
	.back {
		position: absolute;
		inset: 0;
		transform: rotateX(-90deg) translateZ(var(--half));
		background: var(--color-magenta);
		color: #f8f9fa;
	}

	.nav-pill:hover .pill-roll {
		transform: rotateX(90deg);
	}

	/* 當前區塊：墨黑實底反白 */
	.nav-pill.current .front {
		background: var(--color-ink);
		color: #f8f9fa;
	}

	@media (max-width: 720px) {
		.header-inner {
			flex-wrap: wrap;
			gap: 0.4rem;
			padding-top: 0.6rem;
			padding-bottom: 0.6rem;
		}
		.nav-right {
			gap: 1.2rem;
		}
		.pill-face {
			padding: 0.35rem 0.7rem;
		}
	}
</style>
