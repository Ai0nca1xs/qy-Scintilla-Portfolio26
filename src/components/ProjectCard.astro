---
// 「標本卡」：檔案庫網格中的單件作品卡片
import type { CollectionEntry } from 'astro:content';
import { localizePath, useTranslations, type Lang } from '@/i18n/utils';

interface Props {
	entry: CollectionEntry<'projects'>;
	lang: Lang;
}

const { entry, lang } = Astro.props;
const t = useTranslations(lang);
const slug = entry.id.replace(/^(en|fr)\//, '');
const d = entry.data;
---

<a
	href={localizePath(lang, `/project/${slug}`)}
	class="specimen-card"
	data-category={d.category}
	data-cursor-label="VIEW"
>
	<span class="temper-bar" aria-hidden="true"></span>
	<span class="metadata card-meta">
		{d.code} · {d.year}
		{d.status === 'in-progress' && <em class="status-badge">{t.project.statusInProgress}</em>}
	</span>
	<h2 class="card-title">{d.title}</h2>
	<p class="card-summary">{d.summary}</p>
	<span class="metadata card-tags">{d.tags.map((tag) => `[${tag}]`).join(' ')}</span>
</a>

<style>
	.specimen-card {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		padding: 1.4rem 1.4rem 1.6rem;
		border: 1px solid var(--color-line);
		background: rgba(255, 255, 255, 0.4);
		transition:
			border-color 0.4s var(--ease-oxide),
			transform 0.4s var(--ease-oxide);
	}

	/* 頂部「淬鍊光譜」色條：hover 時緩慢升溫（0.4s，呼應氧化概念） */
	.temper-bar {
		display: block;
		height: 2px;
		width: 40%;
		background: var(--calx-linear);
		opacity: 0.55;
		transition:
			width 0.4s var(--ease-oxide),
			opacity 0.4s var(--ease-oxide);
	}

	.specimen-card:hover {
		border-color: rgba(184, 115, 51, 0.5); /* 銅褐：金屬接觸空氣的氧化色 */
		opacity: 1; /* 覆蓋全域 a:hover 的透明度 */
	}

	.specimen-card:hover .temper-bar {
		width: 100%;
		opacity: 1;
	}

	.card-meta {
		display: flex;
		align-items: baseline;
		gap: 0.6rem;
	}

	.status-badge {
		font-style: normal;
		padding: 0 0.4rem;
		border: 1px solid rgba(26, 26, 26, 0.25);
	}

	.card-title {
		font-size: 20px;
		font-weight: 500;
		letter-spacing: -0.01em;
		margin: 0;
	}

	.card-summary {
		font-size: 13px;
		line-height: 1.65;
		color: var(--color-ink-soft);
		margin: 0;
		flex-grow: 1;
	}

	.card-tags {
		margin-top: 0.4rem;
	}
</style>
