---
// 「標本板」：檔案庫中的大畫幅作品板（Mejias 式四角信息佈局）。
// 封面圖就位前以純色分類色作底；把 cover.jpg 放進 src/assets/projects/<slug>/
// 即自動鋪滿、信息疊於其上（也可用 frontmatter 的 cover 指定）。
import type { CollectionEntry } from 'astro:content';
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import { localizePath, useTranslations, type Lang } from '@/i18n/utils';

interface Props {
	entry: CollectionEntry<'projects'>;
	lang: Lang;
}

const { entry, lang } = Astro.props;
const t = useTranslations(lang);
const slug = entry.id.replace(/^(en|fr)\//, '');
const d = entry.data;

// 封面自動裝載：src/assets/projects/<slug>/cover.*（frontmatter cover 優先）
const coverFiles = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/projects/*/cover.{jpg,jpeg,png,webp}',
	{ eager: true }
);
const cover =
	d.cover ??
	Object.entries(coverFiles).find(([path]) => path.includes(`/projects/${slug}/`))?.[1]?.default;
---

<a
	href={localizePath(lang, `/project/${slug}`)}
	class:list={['specimen-plate', { 'has-cover': !!cover }]}
	data-category={d.category}
	data-cursor-label="VIEW"
	style={d.tone ? `--plate: ${d.tone}; --plate-ink: #f8f9fa;` : undefined}
>
	{cover && <Image src={cover} alt={d.title} class="plate-cover" width={1600} />}

	<h2 class="plate-title">{d.title}</h2>
	<span class="metadata plate-year">{d.year}</span>
	<p class="plate-summary">{d.summary}</p>
	<span class="plate-tags">
		{d.status === 'in-progress' && <em class="tag tag-status">{t.project.statusInProgress}</em>}
		{d.tags.map((tag) => <span class="tag">{tag}</span>)}
	</span>
</a>

<style>
	/* 四角網格：左上標題 / 右上年份 / 左下簡介 / 右下標籤，中列自動撐開 */
	.specimen-plate {
		--pad: clamp(1rem, 2.5vw, 2.2rem);
		position: relative;
		display: grid;
		grid-template:
			'title year' auto
			'mid mid' 1fr
			'summary tags' auto
			/ minmax(0, 1fr) auto;
		gap: 1.2rem;
		aspect-ratio: 16 / 9;
		min-height: 400px;
		padding: var(--pad);
		background: var(--plate);
		color: var(--plate-ink, #f8f9fa);
		overflow: hidden;
		transition:
			transform 0.45s var(--ease-spring),
			box-shadow 0.45s var(--ease-oxide);
	}

	/* 懸浮提升：彈簧曲線微升 + 柔影——標本板被「拿起」的觸感（僅指針設備） */
	@media (hover: hover) {
		.specimen-plate:hover {
			transform: translateY(-6px);
			box-shadow: 0 22px 44px -20px rgba(26, 26, 26, 0.35);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.specimen-plate,
		.specimen-plate:hover {
			transform: none;
			transition: none;
		}
	}

	/* 分類 → 純色底（可被 frontmatter 的 tone 覆蓋） */
	.specimen-plate[data-category='GRA'] {
		--plate: var(--cat-gra);
	}
	.specimen-plate[data-category='SCE'] {
		--plate: var(--cat-sce);
	}
	.specimen-plate[data-category='INS'] {
		--plate: var(--cat-ins);
	}
	.specimen-plate[data-category='PRD'] {
		--plate: var(--cat-prd);
		--plate-ink: #1a1a1a;
	}
	.specimen-plate[data-category='PHO'] {
		--plate: var(--cat-pho);
	}

	.plate-cover {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		z-index: 0;
		transition: transform 0.8s var(--ease-oxide);
	}

	.specimen-plate:hover {
		opacity: 1;
	}

	.specimen-plate:hover .plate-cover {
		transform: scale(1.04);
	}

	.plate-title,
	.plate-year,
	.plate-summary,
	.plate-tags {
		position: relative;
		z-index: 1;
	}

	/* 有封面圖時給文字一點投影保證可讀 */
	.has-cover .plate-title,
	.has-cover .plate-summary {
		color: #f8f9fa;
		text-shadow: 0 1px 12px rgba(26, 26, 26, 0.45);
	}

	.plate-title {
		grid-area: title;
		font-size: clamp(1.6rem, 3.4vw, 2.8rem);
		font-weight: 600;
		letter-spacing: -0.02em;
		line-height: 1.05;
		margin: 0;
		transition: transform 0.5s var(--ease-oxide);
	}

	.specimen-plate:hover .plate-title {
		transform: translateX(0.5rem);
	}

	.plate-year {
		grid-area: year;
		justify-self: end;
		color: inherit;
		opacity: 0.85;
	}

	.plate-summary {
		grid-area: summary;
		align-self: end;
		max-width: min(420px, 90%);
		font-size: 12px;
		line-height: 1.8;
		margin: 0;
		opacity: 0.92;
	}

	.plate-tags {
		grid-area: tags;
		justify-self: end;
		align-self: end;
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.4rem;
	}

	/* 純白標籤片：強對比、實驗室標籤氣質（首字母大寫 + 寬字距） */
	.tag {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.1em;
		padding: 4px 9px;
		background: #f8f9fa;
		color: #1a1a1a;
		white-space: nowrap;
	}

	/* 進行中徽章：強調色高亮 */
	.tag-status {
		font-style: normal;
		background: var(--color-accent);
		color: #f8f9fa;
	}

	@media (max-width: 768px) {
		.specimen-plate {
			aspect-ratio: auto;
			min-height: 380px;
			grid-template:
				'title' auto
				'year' auto
				'mid' 1fr
				'summary' auto
				'tags' auto
				/ minmax(0, 1fr);
		}

		.plate-year,
		.plate-tags {
			justify-self: start;
		}

		.plate-tags {
			flex-direction: row;
			flex-wrap: wrap;
			align-items: flex-start;
		}
	}
</style>
