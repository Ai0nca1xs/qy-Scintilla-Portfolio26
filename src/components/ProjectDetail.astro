---
// 作品詳情頁主體：封面 + 規格表（metadata）+ 完整敘述，EN / FR 共用
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import { Image } from 'astro:assets';
import { localizePath, useTranslations, type Lang } from '@/i18n/utils';

interface Props {
	entry: CollectionEntry<'projects'>;
	lang: Lang;
}

const { entry, lang } = Astro.props;
const t = useTranslations(lang);
const d = entry.data;
const { Content } = await render(entry);
---

<article class="project-detail">
	<a href={localizePath(lang, '/project')} class="metadata back-link">{t.project.back}</a>

	<header class="page-header">
		<p class="metadata">
			{d.code} · {t.categories[d.category]} · {d.year}
			{d.status === 'in-progress' && ` · ${t.project.statusInProgress}`}
		</p>
		<h1 class="title-calx detail-title">{d.title}</h1>
		<span class="detail-swatch" data-cat={d.category} aria-hidden="true"></span>
	</header>

	{d.cover && <Image src={d.cover} alt={d.title} class="detail-cover" width={1800} />}

	<dl class="spec-sheet metadata">
		{d.medium && <dt>MEDIUM</dt>}
		{d.medium && <dd>{d.medium}</dd>}
		{d.materials && <dt>MATERIALS</dt>}
		{d.materials && <dd>{d.materials}</dd>}
		{d.dimensions && <dt>DIMENSIONS</dt>}
		{d.dimensions && <dd>{d.dimensions}</dd>}
		{d.exhibitions && <dt>EXHIBITIONS</dt>}
		{d.exhibitions && <dd>{d.exhibitions.map((e) => <span class="exhibition">{e}</span>)}</dd>}
		<dt>KEYWORDS</dt>
		<dd class="tag-chips">
			{d.tags.map((tag) => <span class="detail-tag" data-cat={d.category}>{tag}</span>)}
		</dd>
	</dl>

	<div class="prose">
		<Content />
	</div>
</article>

<style>
	.project-detail {
		max-width: 780px;
		margin: 0 auto;
		padding-bottom: calc(var(--space-lg) * 2);
	}

	.back-link {
		display: inline-block;
		margin-top: var(--space-md);
		opacity: 0.6;
		transition: opacity 0.2s ease;
	}

	.back-link:hover {
		opacity: 1;
	}

	.detail-title {
		font-size: clamp(2rem, 5vw, 3rem);
		font-weight: 600;
	}

	/* 分類色籤：標題下方的一段純色 */
	.detail-swatch {
		display: block;
		width: 56px;
		height: 6px;
		margin-top: 1rem;
	}
	.detail-swatch[data-cat='GRA'] {
		background: var(--cat-gra);
	}
	.detail-swatch[data-cat='SCE'] {
		background: var(--cat-sce);
	}
	.detail-swatch[data-cat='INS'] {
		background: var(--cat-ins);
	}
	.detail-swatch[data-cat='PRD'] {
		background: var(--cat-prd);
	}
	.detail-swatch[data-cat='PHO'] {
		background: var(--cat-pho);
	}

	/* 關鍵詞：分類色實底標籤片 */
	.tag-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.detail-tag {
		padding: 4px 9px;
		color: #f8f9fa;
	}
	.detail-tag[data-cat='GRA'] {
		background: var(--cat-gra);
	}
	.detail-tag[data-cat='SCE'] {
		background: var(--cat-sce);
	}
	.detail-tag[data-cat='INS'] {
		background: var(--cat-ins);
	}
	.detail-tag[data-cat='PRD'] {
		background: var(--cat-prd);
		color: #1a1a1a;
	}
	.detail-tag[data-cat='PHO'] {
		background: var(--cat-pho);
	}

	.detail-cover {
		width: 100%;
		height: auto;
		margin-bottom: var(--space-lg);
	}

	/* 標本規格表：等寬字體的客觀紀錄 */
	.spec-sheet {
		display: grid;
		grid-template-columns: 110px 1fr;
		gap: 0.5rem 1.5rem;
		margin: 0 0 var(--space-lg);
		padding: 1.2rem 0;
		border-top: 1px solid rgba(26, 26, 26, 0.15);
		border-bottom: 1px solid rgba(26, 26, 26, 0.15);
		opacity: 0.7;
	}

	.spec-sheet dt {
		opacity: 0.55;
	}

	.spec-sheet dd {
		margin: 0;
	}

	.exhibition {
		display: block;
	}

	.prose :global(p) {
		font-size: 16px;
		line-height: 1.8;
		margin-bottom: 1.4rem;
	}
</style>
