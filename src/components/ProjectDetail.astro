---
// 作品詳情頁主體：封面 + 規格表（metadata）+ 敘述 + 圖版區，EN / FR 共用。
// 圖版區（WebGLProgressiveBlur 式）：細節圖以大小 / 層次 / 錯落排列組合呈現，
// 滾動時由「失焦」漸進顯影為清晰（離開視口中心再度柔焦）。
// 圖版目前為分類色淡染佔位，素材就位後逐版替換為真實細節圖。
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import { Image } from 'astro:assets';
import { localizePath, useTranslations, type Lang } from '@/i18n/utils';

interface Props {
	entry: CollectionEntry<'projects'>;
	lang: Lang;
}

const { entry, lang } = Astro.props;
const t = useTranslations(lang);
const d = entry.data;
const { Content } = await render(entry);

// 圖版編排：三種節奏行輪換（滿幅 / 高低雙聯 / 錯位寬幅），
// 以作品編碼作種子旋轉起點——每件作品的排列組合都不同。
const seed = [...d.code].reduce((acc, ch) => acc + ch.charCodeAt(0), 0);
const rowPatterns = [
	[{ span: 'plate-full', ratio: '21 / 9' }],
	[
		{ span: 'plate-tall', ratio: '4 / 5' },
		{ span: 'plate-small', ratio: '1 / 1' },
	],
	[{ span: 'plate-wide', ratio: '3 / 2' }],
	[
		{ span: 'plate-half', ratio: '4 / 3' },
		{ span: 'plate-half-low', ratio: '4 / 3' },
	],
];
const plates = [0, 1, 2, 3]
	.map((i) => rowPatterns[(seed + i) % rowPatterns.length])
	.flat()
	.map((p, i) => ({
		...p,
		code: `Plate ${String(i + 1).padStart(2, '0')}`,
		// 淡染深淺輪換，同一頁的佔位版有明暗層次
		mix: [16, 34, 22, 42, 28, 12][i % 6],
		drift: [1, 1.35, 0.75, 1.2, 0.9, 1.45][i % 6],
	}));
---

<article class="project-detail">
	<a href={localizePath(lang, '/project')} class="metadata back-link">{t.project.back}</a>

	<header class="page-header">
		{/* 去分類縮寫：只留具體標籤文字（首字母大寫、字距收緊）+ 年份 */}
		<p class="metadata page-meta">
			{t.categories[d.category]} · {d.year}
			{d.status === 'in-progress' && ` · ${t.project.statusInProgress}`}
		</p>
		<h1 class="title-calx detail-title">{d.title}</h1>
		<span class="detail-swatch" data-cat={d.category} aria-hidden="true"></span>
	</header>

	{d.cover && <Image src={d.cover} alt={d.title} class="detail-cover" width={1800} />}

	<dl class="spec-sheet metadata">
		{d.medium && <dt>Medium</dt>}
		{d.medium && <dd>{d.medium}</dd>}
		{d.materials && <dt>Materials</dt>}
		{d.materials && <dd>{d.materials}</dd>}
		{d.dimensions && <dt>Dimensions</dt>}
		{d.dimensions && <dd>{d.dimensions}</dd>}
		{d.exhibitions && <dt>Exhibitions</dt>}
		{d.exhibitions && <dd>{d.exhibitions.map((e) => <span class="exhibition">{e}</span>)}</dd>}
		<dt>Keywords</dt>
		<dd class="tag-chips">
			{d.tags.map((tag) => <span class="detail-tag" data-cat={d.category}>{tag}</span>)}
		</dd>
	</dl>

	<div class="prose">
		<Content />
	</div>

	{/* —— 圖版區：錯落編排 + 漸進模糊顯影（佔位，素材就位後換圖）—— */}
	<section class="plates" data-cat={d.category} aria-label="Plates">
		{
			plates.map((p) => (
				<figure
					class:list={['plate', p.span]}
					data-plate-blur
					data-drift={p.drift}
					style={`--ratio:${p.ratio}; --mix:${p.mix}%;`}
				>
					<span class="metadata plate-code">{p.code}</span>
					<figcaption class="metadata plate-caption">{d.title} · Detail</figcaption>
				</figure>
			))
		}
	</section>
</article>

<style>
	.project-detail {
		max-width: 1100px;
		margin: 0 auto;
		padding-bottom: calc(var(--space-lg) * 2);
	}

	.back-link {
		display: inline-block;
		margin-top: var(--space-md);
		opacity: 0.6;
		transition: opacity 0.2s ease;
	}

	.back-link:hover {
		opacity: 1;
	}

	.page-meta {
		text-transform: none;
		letter-spacing: 0.02em;
	}

	.detail-title {
		font-size: clamp(2.25rem, 5vw, 3.75rem);
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	/* 分類色籤：標題下方的一段純色 */
	.detail-swatch {
		display: block;
		width: 56px;
		height: 6px;
		margin-top: 1rem;
	}
	.detail-swatch[data-cat='GRA'] {
		background: var(--cat-gra);
	}
	.detail-swatch[data-cat='SCE'] {
		background: var(--cat-sce);
	}
	.detail-swatch[data-cat='INS'] {
		background: var(--cat-ins);
	}
	.detail-swatch[data-cat='PRD'] {
		background: var(--cat-prd);
	}
	.detail-swatch[data-cat='PHO'] {
		background: var(--cat-pho);
	}

	/* 關鍵詞：分類色實底標籤片 */
	.tag-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.detail-tag {
		padding: 4px 9px;
		color: #f8f9fa;
	}
	.detail-tag[data-cat='GRA'] {
		background: var(--cat-gra);
	}
	.detail-tag[data-cat='SCE'] {
		background: var(--cat-sce);
	}
	.detail-tag[data-cat='INS'] {
		background: var(--cat-ins);
	}
	.detail-tag[data-cat='PRD'] {
		background: var(--cat-prd);
		color: #1a1a1a;
	}
	.detail-tag[data-cat='PHO'] {
		background: var(--cat-pho);
	}

	.detail-cover {
		width: 100%;
		height: auto;
		margin-bottom: var(--space-lg);
	}

	/* 標本規格表：無框化——留白 + 字重對比替代邊線 */
	.spec-sheet {
		display: grid;
		grid-template-columns: 110px 1fr;
		gap: 0.5rem 1.5rem;
		max-width: 720px;
		margin: 0 auto var(--space-lg);
		padding: 1.2rem 0;
		opacity: 0.7;
	}

	.spec-sheet dt {
		opacity: 0.55;
	}

	.spec-sheet dd {
		margin: 0;
	}

	.exhibition {
		display: block;
	}

	/* 內文窄欄：12px 字體的欄寬鐵律（400–500px） */
	.prose {
		max-width: 480px;
		margin: 0 auto;
	}

	.prose :global(p) {
		margin-bottom: 1.4rem;
	}

	/* —— 圖版區 —— */
	.plates {
		display: grid;
		grid-template-columns: repeat(12, 1fr);
		gap: clamp(16px, 3vw, 40px);
		margin-top: calc(var(--space-lg) * 1.5);
	}

	.plate {
		position: relative;
		margin: 0;
		aspect-ratio: var(--ratio);
		border-radius: var(--radius-md);
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		padding: 16px;
		box-sizing: border-box;
		will-change: filter, transform, opacity;
	}

	/* 佔位淡染：分類色 × 白，深淺依 --mix 輪換 */
	.plates[data-cat='GRA'] .plate {
		background: color-mix(in srgb, var(--cat-gra) var(--mix), #ffffff);
	}
	.plates[data-cat='SCE'] .plate {
		background: color-mix(in srgb, var(--cat-sce) var(--mix), #ffffff);
	}
	.plates[data-cat='INS'] .plate {
		background: color-mix(in srgb, var(--cat-ins) var(--mix), #ffffff);
	}
	.plates[data-cat='PRD'] .plate {
		background: color-mix(in srgb, var(--cat-prd) var(--mix), #ffffff);
	}
	.plates[data-cat='PHO'] .plate {
		background: color-mix(in srgb, var(--cat-pho) var(--mix), #ffffff);
	}

	/* 圖注：Roboto Mono Italic 微型字級（程式碼註解式的技術感） */
	.plate-code,
	.plate-caption {
		position: relative;
		z-index: 1;
		opacity: 0.5;
		font-style: italic;
		font-size: 10px;
	}

	/* 排列組合：滿幅 / 高低雙聯 / 錯位寬幅 / 錯層對半 */
	.plate-full {
		grid-column: 1 / -1;
	}
	.plate-tall {
		grid-column: 1 / 8;
	}
	.plate-small {
		grid-column: 9 / -1;
		align-self: end;
		margin-bottom: clamp(24px, 8vw, 96px);
	}
	.plate-wide {
		grid-column: 3 / -1;
	}
	.plate-half {
		grid-column: 1 / 7;
	}
	.plate-half-low {
		grid-column: 7 / -1;
		margin-top: clamp(32px, 10vw, 128px);
	}

	@media (max-width: 720px) {
		.plate-tall,
		.plate-small,
		.plate-wide,
		.plate-half,
		.plate-half-low {
			grid-column: 1 / -1;
			margin-top: 0;
			margin-bottom: 0;
		}
	}
</style>

<script>
	import { initTypeShuffle } from '@/scripts/text-motion';

	// ① 敘述首段標記為「解碼」載入（長篇說明性文字的 Type Shuffle）
	// ② 圖版漸進模糊：以視口中心為焦平面，圖版靠近則顯影清晰、遠離則柔焦，滾動連續驅動
	function initDetailEffects() {
		const firstPara = document.querySelector<HTMLElement>('.prose p');
		if (firstPara && !firstPara.hasAttribute('data-ts-ready')) {
			firstPara.setAttribute('data-type-shuffle', '');
			initTypeShuffle();
		}

		const plates = Array.from(document.querySelectorAll<HTMLElement>('[data-plate-blur]'));
		if (!plates.length) return;
		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

		let rafId = 0;
		const update = () => {
			rafId = 0;
			const vh = window.innerHeight;
			for (const el of plates) {
				const r = el.getBoundingClientRect();
				if (r.bottom < -160 || r.top > vh + 160) continue;
				const drift = parseFloat(el.dataset.drift ?? '1');
				// 與視口中心的歸一化距離 → 焦外量（中心 ±30% 為清晰區）
				const dist = Math.abs(r.top + r.height / 2 - vh / 2) / (vh * 0.72);
				const defocus = Math.min(1, Math.max(0, (dist - 0.3) / 0.7));
				el.style.filter = defocus < 0.01 ? 'none' : `blur(${(defocus * 14).toFixed(2)}px)`;
				el.style.opacity = (1 - defocus * 0.55).toFixed(3);
				el.style.transform =
					defocus < 0.01 ? 'none' : `translateY(${(defocus * 26 * drift).toFixed(2)}px)`;
			}
		};
		const onScroll = () => {
			if (!rafId) rafId = requestAnimationFrame(update);
		};

		update();
		window.addEventListener('scroll', onScroll, { passive: true });
		window.addEventListener('resize', onScroll, { passive: true });
		document.addEventListener(
			'astro:before-swap',
			() => {
				cancelAnimationFrame(rafId);
				window.removeEventListener('scroll', onScroll);
				window.removeEventListener('resize', onScroll);
			},
			{ once: true }
		);
	}

	document.addEventListener('astro:page-load', initDetailEffects);
</script>
