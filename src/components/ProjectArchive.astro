---
// 檔案庫頁主體：分類篩選 + 標本卡網格，EN / FR 共用
import { getCollection } from 'astro:content';
import ProjectCard from '@/components/ProjectCard.astro';
import { useTranslations, type Lang } from '@/i18n/utils';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const localePrefix = lang === 'FR' ? 'fr/' : 'en/';

// 預設排序：按年份從新到舊。年份是字符串（支持 '2019–2024'、'2026–27' 跨度），
// 取跨度的結束年比較；同年再按 order。
const endYear = (year: string) => {
	const full = year.match(/\d{4}/g);
	if (!full) return 0;
	let latest = Math.max(...full.map(Number));
	const short = year.match(/[–-](\d{2})\s*$/);
	if (short) latest = Math.max(latest, Math.floor(latest / 100) * 100 + Number(short[1]));
	return latest;
};

const entries = (await getCollection('projects', ({ id }) => id.startsWith(localePrefix))).sort(
	(a, b) => endYear(b.data.year) - endYear(a.data.year) || a.data.order - b.data.order
);

const categories = ['GRA', 'SCE', 'INS', 'PRD', 'PHO'] as const;
---

<header class="page-header">
	<h1 class="title-calx">{t.project.heading}</h1>
	<p class="metadata">
		Sort by: year ↓ | Filter: <span data-filter-label>{t.project.filterAll}</span>
	</p>
</header>

<nav class="filter-bar" aria-label="Category filter">
	<button class="filter-btn metadata active" data-filter="ALL">{t.project.filterAll}</button>
	{
		categories.map((cat) => (
			<button class="filter-btn metadata" data-filter={cat}>
				<span class="filter-dot" data-cat={cat} aria-hidden="true" />
				{t.categoriesShort[cat]}
			</button>
		))
	}
</nav>

<section class="plate-stack" data-project-grid>
	{entries.map((entry) => <ProjectCard entry={entry} lang={lang} />)}
</section>

<style>
	.filter-bar {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-bottom: var(--space-lg);
	}

	/* 無框膠囊：淡染實底替代描邊。
	   標籤只留具體文字（去分類縮寫），首字母大寫、字距收緊 */
	.filter-btn {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		height: var(--btn-height); /* 全站按鈕統一高度 */
		background: rgba(26, 26, 26, 0.05);
		border: none;
		padding: 8px 16px;
		cursor: pointer;
		opacity: 0.7;
		text-transform: none;
		letter-spacing: 0.02em;
		transition: all 0.4s var(--ease-oxide);
	}

	.filter-btn:hover {
		opacity: 1;
		color: var(--color-accent);
		background: rgba(26, 26, 26, 0.08);
	}

	/* 選中態：墨黑實底反白，強對比 */
	.filter-btn.active {
		opacity: 1;
		background: var(--color-ink);
		color: #f8f9fa;
	}

	/* 分類色點 */
	.filter-dot {
		width: 8px;
		height: 8px;
		flex-shrink: 0;
	}
	.filter-dot[data-cat='GRA'] {
		background: var(--cat-gra);
	}
	.filter-dot[data-cat='SCE'] {
		background: var(--cat-sce);
	}
	.filter-dot[data-cat='INS'] {
		background: var(--cat-ins);
	}
	.filter-dot[data-cat='PRD'] {
		background: var(--cat-prd);
	}
	.filter-dot[data-cat='PHO'] {
		background: var(--cat-pho);
	}

	/* 大圖板縱向堆疊，窄間隙 */
	.plate-stack {
		display: flex;
		flex-direction: column;
		gap: clamp(0.8rem, 1.5vw, 1.5rem);
	}

	/* 篩選切換：板以「沉澱/顯影」的方式離場入場 */
	.plate-stack :global(.is-hidden) {
		display: none;
	}

	.plate-stack :global([data-category]) {
		animation: card-develop 0.6s cubic-bezier(0.22, 1, 0.36, 1) backwards;
		/* 級差顯影：可見卡片依序遲滯（--dev-i 由腳本按可見順位賦值），如相紙逐張顯影 */
		animation-delay: calc(var(--dev-i, 0) * 70ms);
	}

	@keyframes card-develop {
		from {
			opacity: 0;
			filter: blur(4px);
			transform: translateY(8px);
		}
		to {
			opacity: 1;
			filter: blur(0);
			transform: translateY(0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.plate-stack :global([data-category]) {
			animation: none;
		}
	}
</style>

<script>
	// 分類篩選。astro:page-load 兼容首次載入與轉場後的重新綁定。
	// 支持 ?lens=GRA 這類預篩選鏈接（首頁領域跳轉 / 求職投遞專用視角）。
	function initProjectFilters() {
		const grid = document.querySelector<HTMLElement>('[data-project-grid]');
		if (!grid) return;

		const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('.filter-btn'));
		const label = document.querySelector('[data-filter-label]');
		const cards = Array.from(grid.querySelectorAll<HTMLElement>('[data-category]'));

		const applyFilter = (btn: HTMLButtonElement) => {
			const filter = btn.dataset.filter ?? 'ALL';
			buttons.forEach((b) => b.classList.toggle('active', b === btn));
			if (label) label.textContent = (btn.textContent ?? '').trim();

			let visibleIndex = 0;
			cards.forEach((card) => {
				const show = filter === 'ALL' || card.dataset.category === filter;
				card.classList.toggle('is-hidden', !show);
				if (show) {
					// 依可見順位賦級差，再重觸發顯影動畫——「重新校準光譜」逐張顯影
					card.style.setProperty('--dev-i', String(visibleIndex++));
					card.style.animation = 'none';
					void card.offsetWidth;
					card.style.animation = '';
				}
			});
		};

		buttons.forEach((btn) => {
			btn.addEventListener('click', () => applyFilter(btn));
		});

		// 首次載入：給全部卡片賦級差順位（無 lens 時 applyFilter 不會跑）
		cards.forEach((card, i) => card.style.setProperty('--dev-i', String(i)));

		// URL 帶 lens 參數時，載入即校準到對應分類
		const lens = new URLSearchParams(window.location.search).get('lens')?.toUpperCase();
		if (lens) {
			const target = buttons.find((b) => b.dataset.filter === lens);
			if (target) applyFilter(target);
		}
	}

	document.addEventListener('astro:page-load', initProjectFilters);
</script>
