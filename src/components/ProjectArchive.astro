---
// 檔案庫頁主體（cargo 3290656「書籍目錄」語法）：
// 三大領域作「部」（I / II / III 羅馬數字 + 巨型標題），
// 作品作「章」——編號全書連續，行末以點狀引導線接右對齊的年份（如目錄頁碼）。
// ?lens=GRA 等預篩選鏈接改為滾動至對應「部」的錨點。EN / FR 共用。
import { getCollection } from 'astro:content';
import { localizePath, useTranslations, type Lang } from '@/i18n/utils';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const localePrefix = lang === 'FR' ? 'fr/' : 'en/';

// 年份排序：字符串年份（支持 '2019–2024'、'2026–27' 跨度）取結束年，同年按 order
const endYear = (year: string) => {
	const full = year.match(/\d{4}/g);
	if (!full) return 0;
	let latest = Math.max(...full.map(Number));
	const short = year.match(/[–-](\d{2})\s*$/);
	if (short) latest = Math.max(latest, Math.floor(latest / 100) * 100 + Number(short[1]));
	return latest;
};

const entries = (await getCollection('projects', ({ id }) => id.startsWith(localePrefix))).sort(
	(a, b) => endYear(b.data.year) - endYear(a.data.year) || a.data.order - b.data.order
);

const slugOf = (id: string) => id.replace(/^(en|fr)\//, '');
const ROMAN = ['I', 'II', 'III', 'IV', 'V'];

// 以首頁的三大領域分「部」；行號全書連續（目錄的章序邏輯）
const parts = t.home.domains.map((domain, i) => ({
	roman: ROMAN[i],
	title: domain.title,
	lens: domain.lens,
	blurb: domain.blurb,
	items: entries.filter((e) => (domain.cats as readonly string[]).includes(e.data.category)),
}));
let rowNo = 0;
---

<header class="page-header">
	<h1 class="title-calx">{t.project.heading}</h1>
	<p class="metadata">Index · {entries.length} works · sort by year ↓</p>
</header>

<section class="toc" data-project-toc>
	{
		parts.map((part) => (
			<div class="toc-part" id={`part-${part.lens}`}>
				<h2 class="part-title">
					<span class="part-roman">{part.roman}</span>
					{part.title}
				</h2>
				<p class="part-blurb">{part.blurb}</p>
				<ol class="toc-list">
					{part.items.map((entry) => {
						rowNo += 1;
						return (
							<li>
								<a
									href={localizePath(lang, `/project/${slugOf(entry.id)}`)}
									class="toc-row"
									style={`--dev-i: ${rowNo}`}
									data-cursor-label="VIEW"
								>
									<span class="caption-mono toc-no">{String(rowNo).padStart(2, '0')}</span>
									<span class="toc-title">
										{entry.data.title}
										{entry.data.status === 'in-progress' && (
											<em class="caption-mono toc-status">{t.project.statusInProgress}</em>
										)}
									</span>
									<span class="toc-leader" aria-hidden="true" />
									<span class="metadata toc-year">{entry.data.year}</span>
								</a>
							</li>
						);
					})}
				</ol>
			</div>
		))
	}
</section>

<style>
	.toc {
		display: flex;
		flex-direction: column;
		gap: calc(var(--space-lg) * 1.4);
		margin-bottom: var(--space-xl);
	}

	/* 「部」標題：目錄裡的巨型羅馬數字 + 領域名（cargo 3290656 的 7rem 級數） */
	.part-title {
		display: flex;
		align-items: baseline;
		gap: 1.4rem;
		font-size: clamp(1.9rem, 5.2vw, 4.2rem);
		letter-spacing: -0.02em;
		line-height: 1.05;
		margin-bottom: 0.6rem;
	}

	.part-roman {
		font-weight: 400;
		font-size: 0.62em;
		color: var(--color-accent);
	}

	.part-blurb {
		color: var(--text-secondary);
		max-width: 480px;
		margin-bottom: 1.6rem;
	}

	.toc-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	/* 章行：編號 · 標題 ····· 年份（頁碼位）；髮絲線分隔 */
	.toc-row {
		display: flex;
		align-items: baseline;
		gap: 1rem;
		padding: 0.85rem 0;
		border-top: 1px solid var(--color-line);
		animation: row-develop 0.6s var(--ease-develop) backwards;
		animation-delay: calc(var(--dev-i, 0) * 60ms);
	}

	.toc-list li:last-child .toc-row {
		border-bottom: 1px solid var(--color-line);
	}

	.toc-no {
		font-style: normal;
		min-width: 2.2em;
		opacity: 0.7;
	}

	.toc-title {
		font-family: var(--font-title);
		font-size: clamp(16px, 2vw, 20px);
		font-weight: 500;
		letter-spacing: -0.01em;
		transition: transform 0.45s var(--ease-spring);
	}

	.toc-status {
		margin-left: 0.8em;
		color: var(--color-accent);
	}

	/* 點狀引導線：目錄「標題→頁碼」的視覺韻腳 */
	.toc-leader {
		flex: 1;
		border-bottom: 1px dotted rgba(26, 26, 26, 0.3);
		transform: translateY(-0.28em);
	}

	.toc-year {
		opacity: 0.8;
		font-variant-numeric: tabular-nums;
	}

	.toc-row:hover {
		opacity: 1;
	}

	.toc-row:hover .toc-title {
		transform: translateX(0.5rem);
		color: var(--color-accent);
	}

	.toc-row:hover .toc-leader {
		border-color: var(--color-accent);
	}

	@keyframes row-develop {
		from {
			opacity: 0;
			filter: blur(4px);
			transform: translateY(8px);
		}
		to {
			opacity: 1;
			filter: blur(0);
			transform: translateY(0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.toc-row {
			animation: none;
		}
	}

	@media (max-width: 720px) {
		.toc-leader {
			display: none;
		}

		.toc-row {
			flex-wrap: wrap;
			gap: 0.4rem 1rem;
		}

		.toc-year {
			margin-left: auto;
		}
	}
</style>

<script>
	// ?lens=GRA 等舊篩選鏈接 → 滾動至對應「部」
	function initTocLens() {
		const lens = new URLSearchParams(window.location.search).get('lens')?.toUpperCase();
		if (!lens) return;
		const target = document.getElementById(`part-${lens}`);
		target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
	}
	document.addEventListener('astro:page-load', initTocLens);
</script>
