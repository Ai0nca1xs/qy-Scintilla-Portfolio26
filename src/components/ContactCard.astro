---
// 名片式聯繫頁主體：懸停時微翹並自動翻面（離開翻回），鍵盤可切換。
// 卡面圖片就位後自動替換：把設計好的圖放到
//   src/assets/contact/card-front.(jpg|png)  正面
//   src/assets/contact/card-back.(jpg|png)   背面
// 找不到圖片時回退到目前的排版設計。
// CV 文件放在 public/cv/HE-Qianyu-CV.pdf（見 docs/how-to-add-media.md）。
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import { useTranslations, withBase, type Lang } from '@/i18n/utils';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const cardImages = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/contact/card-*.{jpg,jpeg,png,webp}',
	{ eager: true }
);
const frontImg = Object.entries(cardImages).find(([path]) => path.includes('card-front'))?.[1]
	?.default;
const backImg = Object.entries(cardImages).find(([path]) => path.includes('card-back'))?.[1]
	?.default;
---

<div class="card-stage">
	<div class="card-scene">
		<article
			class="biz-card"
			data-cursor-label="FLIP"
			tabindex="0"
			role="button"
			aria-label="Flip the card"
		>
			<div class="card-face card-front">
				{
					frontImg ? (
						<Image src={frontImg} alt="HE Qianyu — carte" class="card-img" width={1200} />
					) : (
						<>
							<span class="metadata card-tag">SCINTILLA — Contact</span>
							<div class="card-core">
								<h1 class="card-name">HE QIANYU</h1>
								<p class="card-role">{t.contact.role}</p>
							</div>
							<span class="metadata card-flip-hint">Flip →</span>
							<span class="card-swatch" aria-hidden="true" />
						</>
					)
				}
			</div>

			<div class="card-face card-back">
				{
					backImg ? (
						<Image src={backImg} alt="HE Qianyu — carte (verso)" class="card-img" width={1200} />
					) : (
						<>
							<span class="metadata card-tag back-tag">⌮ Specimen n° 001 — Designer</span>
							<div class="card-core">
								<span class="card-mailline">{t.contact.email}</span>
								<span class="metadata back-meta">{t.contact.location}</span>
								<span class="metadata back-meta">EN · FR · ZH · JP</span>
							</div>
							<span class="metadata card-flip-hint">← Back</span>
						</>
					)
				}
			</div>
		</article>
	</div>

	<div class="card-actions">
		<a class="card-mail" href={`mailto:${t.contact.email.toLowerCase()}`}>{t.contact.email}</a>
		<a class="cv-btn" href={withBase('/cv/HE-Qianyu-CV.pdf')} download>
			{t.contact.cvButton} ↓
		</a>
		<p class="card-note" set:html={t.contact.blurbHtml} />
	</div>
</div>

<style>
	.card-stage {
		min-height: calc(100svh - 220px);
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		gap: var(--space-lg);
		padding: var(--space-lg) 0;
	}

	/* 3D 舞台：懸停微翹作用在 scene 上，翻轉作用在卡牌上，兩者互不打架 */
	.card-scene {
		perspective: 1400px;
		transition: transform 0.5s var(--ease-spring);
	}

	.card-scene:hover {
		transform: rotate(-1.2deg) translateY(-5px);
	}

	.biz-card {
		position: relative;
		width: min(560px, 92vw);
		aspect-ratio: 17 / 10;
		transform-style: preserve-3d;
		transition: transform 0.85s var(--ease-spring);
		cursor: none;
	}

	.biz-card.flipped {
		transform: rotateY(180deg);
	}

	.card-face {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		padding: clamp(1.2rem, 3vw, 2rem);
		/* 液態玻璃卡面：半透明 + 背景模糊，透出底層光譜（無框，投影界定體積）*/
		background: rgba(253, 253, 254, 0.55);
		-webkit-backdrop-filter: blur(20px) saturate(1.5);
		backdrop-filter: blur(20px) saturate(1.5);
		border-radius: var(--radius-lg);
		box-shadow: 0 18px 50px -30px rgba(26, 26, 26, 0.35);
		backface-visibility: hidden;
		overflow: hidden;
	}

	/* 背面：墨黑反白，像卡牌的花色面 */
	.card-back {
		transform: rotateY(180deg);
		background: var(--color-ink);
		color: #f8f9fa;
	}

	.card-back .metadata {
		opacity: 0.6;
	}

	/* 卡面圖片模式：圖片鋪滿整張卡 */
	.card-img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.card-tag {
		opacity: 0.45;
	}

	.card-name {
		font-size: clamp(1.8rem, 4.5vw, 2.6rem);
		font-weight: 700;
		letter-spacing: 0.01em;
		margin: 0 0 0.4rem;
	}

	.card-role {
		font-size: 14px;
		color: var(--color-ink-soft);
		margin: 0;
	}

	.card-mailline {
		display: block;
		font-size: clamp(1.1rem, 2.6vw, 1.5rem);
		font-weight: 500;
		letter-spacing: 0.03em;
		margin-bottom: 0.6rem;
	}

	.back-meta {
		display: block;
		margin-top: 0.2rem;
	}

	.card-flip-hint {
		opacity: 0.4;
		align-self: flex-end;
	}

	/* 強調色籤：正面右上角的一枚純色 */
	.card-swatch {
		position: absolute;
		top: clamp(1.2rem, 3vw, 2rem);
		right: clamp(1.2rem, 3vw, 2rem);
		width: 16px;
		height: 16px;
		background: var(--color-accent);
	}

	.card-actions {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.9rem;
	}

	.card-mail {
		font-size: clamp(1rem, 2.4vw, 1.25rem);
		font-weight: 500;
		letter-spacing: 0.03em;
		transition: color 0.3s ease;
	}

	.card-mail:hover {
		opacity: 1;
		color: var(--color-accent);
	}

	/* CV 下載按鈕：墨黑實底，懸停翻洋紅 */
	.cv-btn {
		display: inline-flex;
		align-items: center;
		min-height: 44px; /* 移動端點擊熱區 ≥44px */
		padding: 12px 24px;
		border-radius: var(--radius-sm);
		background: var(--color-ink);
		color: #f8f9fa;
		font-size: 12px;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		transition:
			background 0.4s var(--ease-oxide),
			transform 0.45s var(--ease-spring);
	}

	.cv-btn:hover {
		opacity: 1;
		background: var(--color-accent);
		transform: translateY(-2px);
	}

	.card-note {
		font-size: 14px;
		text-align: center;
		color: var(--color-ink-soft);
		margin: 0;
	}
</style>

<script>
	// 卡牌翻轉：懸浮自動翻面（離開翻回）；鍵盤 Enter / 空格保留無障礙切換
	function initCardFlip() {
		const card = document.querySelector('.biz-card');
		if (!(card instanceof HTMLElement)) return;

		card.addEventListener('pointerenter', () => card.classList.add('flipped'));
		card.addEventListener('pointerleave', () => card.classList.remove('flipped'));
		card.addEventListener('keydown', (e) => {
			if (e.key === 'Enter' || e.key === ' ') {
				e.preventDefault();
				card.classList.toggle('flipped');
			}
		});
	}

	document.addEventListener('astro:page-load', initCardFlip);
</script>
