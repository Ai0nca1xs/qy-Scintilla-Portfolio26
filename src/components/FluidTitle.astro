---
// 首頁標題「流體墨水」互動（Ksenia Kondrashova «WebGL Fluid Simulation With Your Text» 移植，
// 基於 Pavel Dobryakov 的 WebGL Fluid Simulation）。
// 畫布鋪滿整個 hero：游標在任意處攪動墨水，字形「留住」墨水而漸漸顯影；
// 未互動時自動巡遊預覽。輸出帶 alpha，無墨處透明，透出底層 HeroField 光場。
// 若 WebGL / 浮點紋理不支援或初始化失敗，保留純黑 DOM 標題（.ft-fallback），永不開天窗。
interface Props {
	text?: string;
	meta?: string;
}
const { text = 'SCINTILLA.', meta = '' } = Astro.props;
---

<div class="fluid-stage" data-fluid-title data-text={text} data-meta={meta}>
	{/* 可訪問 / SEO 用真實標題；流體就緒後隱藏（保留於無障礙樹），視覺由 canvas 積墨顯影 */}
	<h1 class="ft-fallback"><span class="ft-word">SCINTILLA</span><span class="ft-dot">.</span></h1>
	{meta && <span class="ft-meta metadata">{meta}</span>}
	<canvas class="ft-canvas" data-fluid-canvas aria-hidden="true"></canvas>
</div>

<style>
	/* 鋪滿 hero 的舞台層：位於 HeroField 之上、hero 內容之下，不攔截任何指針事件 */
	.fluid-stage {
		position: absolute;
		inset: 0;
		z-index: 0;
		pointer-events: none;
	}

	.ft-fallback {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		white-space: nowrap;
		font-size: clamp(3.4rem, 14vw, 11rem);
		font-weight: 700;
		line-height: 0.95;
		letter-spacing: -0.02em;
		margin: 0;
		color: var(--color-ink);
	}
	.ft-dot {
		color: var(--color-magenta);
	}

	/* meta 句（Residue of a thousand burnt eras）：標題下方，與標題同屬墨水圖層 */
	.ft-meta {
		position: absolute;
		top: calc(50% + clamp(3.4rem, 14vw, 11rem) * 0.62);
		left: 50%;
		transform: translateX(-50%);
		white-space: nowrap;
	}
	.fluid-stage.ready .ft-meta {
		visibility: hidden;
	}

	.ft-canvas {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		opacity: 0;
		transition: opacity 0.6s ease;
	}
	.fluid-stage.ready .ft-canvas {
		opacity: 1;
	}
	/* 流體接管後隱藏 DOM 文字（保留於無障礙樹），標題由積墨顯影 */
	.fluid-stage.ready .ft-fallback {
		visibility: hidden;
	}

	@media (prefers-reduced-motion: reduce) {
		.ft-canvas {
			display: none;
		}
	}
</style>

<script>
	import { initFluidTitle } from '@/scripts/fluid-title';
	document.addEventListener('astro:page-load', () => {
		const root = document.querySelector<HTMLElement>('[data-fluid-title]');
		if (!root) return;
		// 等 Roboto Mono 就緒再生成文字貼圖，避免流體標題用回退字體渲染
		document.fonts.ready.then(() => initFluidTitle(root));
	});
	document.addEventListener('astro:before-swap', () => {
		window.dispatchEvent(new CustomEvent('fluid-title:destroy'));
	});
</script>
