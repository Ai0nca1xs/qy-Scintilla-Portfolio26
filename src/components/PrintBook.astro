			.g-cell {
				display: flex;
				flex-direction: column;
				gap: 1.4mm;
			}
			.gallery-mosaic :global(img.g-img),
			.g-block {
				width: 100%;
				height: 52mm;
				object-fit: cover;
			}
			/* 首頁帶說明行時稍矮；後續整頁馬賽克可高一些 */
			.gallery-mosaic.tall :global(img.g-img),
			.gallery-mosaic.tall .g-block {
				height: 60mm;
			}
			.g-block {
				display: flex;
				align-items: flex-end;
				padding: 4mm;
				box-sizing: border-box;
			}
			.g-block span {
				font-family: var(--mono);
				font-size: 6.5pt;
				letter-spacing: 0.12em;
				opacity: 0.75;
			}
			.g-title {
				font-family: var(--mono);
				font-weight: 700;
				font-size: 8pt;
				text-transform: uppercase;
				letter-spacing: 0.02em;
			}
			.g-line {
				font-family: var(--mono);
				font-style: italic;
				font-size: 6.5pt;
				color: var(--ink-2);
			}

			/* ——— 作品續頁：2×2 大圖網格 ——— */
			.extra-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				grid-auto-rows: 1fr;
				gap: 8mm;
				height: calc(100% - 16mm);
			}
			.extra-grid :global(img) {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}
			.extra-grid.single {
				grid-template-columns: 1fr;
			}

			/* ——— 封底 ——— */
			.back {
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: flex-start;
			}
			.back-thanks {
				font-family: var(--sans);
				font-weight: 700;
				font-size: 40pt;
				letter-spacing: -0.02em;
				margin: 0 0 12mm;
			}
			.back-contact {
				display: flex;
				flex-direction: column;
				gap: 2mm;
				font-family: var(--mono);
				font-size: 8.5pt;
				letter-spacing: 0.06em;
				color: var(--ink-2);
			}
			.back-folio {
