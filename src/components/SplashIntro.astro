---
// 開屏動畫：世界觀的展開（白底光感版）。
// 與首頁 HeroField 同一套光譜雲氣著色器，白底之上以顏色表現光感；無文字。
// 載入後中心白光逐漸放大鋪滿畫面，隨即淡出自動進入首頁——與首頁的光譜雲氣無縫銜接。
// 每個瀏覽會話只播放一次（sessionStorage），減弱動效直接跳過。
---

<div class="splash" data-splash aria-hidden="true">
	<canvas class="splash-canvas" data-splash-canvas></canvas>
</div>

<style>
	.splash {
		position: fixed;
		inset: 0;
		z-index: 9600;
		background: #ffffff;
		transition: opacity 0.9s var(--ease-develop);
	}
	.splash.done {
		opacity: 0;
		pointer-events: none;
	}
	.splash-canvas {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
	}
</style>

<script>
	const SEEN_KEY = 'scintilla-splash-seen';

	const FRAG = `
precision highp float;
uniform float u_t;
uniform vec2 u_r;
uniform float u_bloom;

// 液態金屬循環色板：靛藍 → 金 → 暗酒紅（循環）
vec3 metal(float t){
	t = fract(t);
	vec3 indigo = vec3(0.16, 0.20, 0.52);
	vec3 gold   = vec3(0.85, 0.66, 0.16);
	vec3 wine   = vec3(0.36, 0.09, 0.17);
	if (t < 0.3333) return mix(indigo, gold, t / 0.3333);
	else if (t < 0.6666) return mix(gold, wine, (t - 0.3333) / 0.3333);
	return mix(wine, indigo, (t - 0.6666) / 0.3334);
}

mat2 rot(float a){ return mat2(cos(a), -sin(a), sin(a), cos(a)); }

void main(){
	// 中心化 + 等比 + 緩慢整體旋轉
	vec2 pc = (gl_FragCoord.xy - 0.5 * u_r) / u_r.y;
	vec2 p = rot(u_t * 0.05) * pc;

	// —— XsXXDn「Creation」原始 fract 環狀折疊結構 ——
	vec3 c;
	float l, z = u_t;
	for (int i = 0; i < 3; i++) {
		vec2 pp = p;
		vec2 uv = pp + 0.5;
		z += 0.07;
		l = length(pp);
		uv += pp / l * (sin(z) + 1.0) * abs(sin(l * 9.0 - z - z));
		c[i] = 0.01 / length(mod(uv, 1.0) - 0.5);
	}
	float field = clamp((c.x + c.y + c.z) / 3.0 / max(l, 0.001), 0.0, 1.0);

	// 階梯量化 → 清晰等高線色帶
	const float BANDS = 6.0;
	float q = floor(field * BANDS) / BANDS;

	// 液態金屬上色（場值 + 時間偏移循環）
	vec3 metalCol = metal(q + u_t * 0.03);

	// 白底合成：場強越高越顯金屬色，邊緣淡出保持通透
	float vig = smoothstep(1.1, 0.15, length(pc));
	float amt = clamp(field * 1.15 * vig, 0.0, 0.92);
	vec3 col = mix(vec3(1.0), metalCol, amt);

	// 中心白光：bloom 增大時放大鋪滿全屏
	float rr = 0.09 + u_bloom * 1.75;
	float disc = smoothstep(rr, rr - 0.28, length(pc));
	col = mix(col, vec3(1.0), disc);

	gl_FragColor = vec4(col, 1.0);
}`;

	const VERT = `attribute vec2 a_pos; void main(){ gl_Position = vec4(a_pos, 0.0, 1.0); }`;

	function startShader(canvas: HTMLCanvasElement) {
		const gl = canvas.getContext('webgl', { antialias: false, alpha: false });
		if (!gl) return null;
		const compile = (type: number, src: string) => {
			const s = gl.createShader(type)!;
			gl.shaderSource(s, src);
			gl.compileShader(s);
			return s;
		};
		const program = gl.createProgram()!;
		gl.attachShader(program, compile(gl.VERTEX_SHADER, VERT));
		gl.attachShader(program, compile(gl.FRAGMENT_SHADER, FRAG));
		gl.linkProgram(program);
		if (!gl.getProgramParameter(program, gl.LINK_STATUS)) return null;
		gl.useProgram(program);

		const buf = gl.createBuffer();
		gl.bindBuffer(gl.ARRAY_BUFFER, buf);
		gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 3, -1, -1, 3]), gl.STATIC_DRAW);
		const loc = gl.getAttribLocation(program, 'a_pos');
		gl.enableVertexAttribArray(loc);
		gl.vertexAttribPointer(loc, 2, gl.FLOAT, false, 0, 0);

		const uT = gl.getUniformLocation(program, 'u_t');
		const uR = gl.getUniformLocation(program, 'u_r');
		const uB = gl.getUniformLocation(program, 'u_bloom');

		const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
		const resize = () => {
			canvas.width = Math.floor(canvas.clientWidth * dpr);
			canvas.height = Math.floor(canvas.clientHeight * dpr);
			gl.viewport(0, 0, canvas.width, canvas.height);
		};
		resize();
		window.addEventListener('resize', resize);

		let rafId = 0;
		let bloom = 0;
		let bloomTarget = 0;
		const start = performance.now();
		const frame = () => {
			bloom += (bloomTarget - bloom) * 0.05;
			gl.uniform1f(uT, (performance.now() - start) / 1000);
			gl.uniform2f(uR, canvas.width, canvas.height);
			gl.uniform1f(uB, bloom);
			gl.drawArrays(gl.TRIANGLES, 0, 3);
			rafId = requestAnimationFrame(frame);
		};
		frame();

		return {
			igniteBloom: () => {
				bloomTarget = 1.15;
			},
			stop: () => {
				cancelAnimationFrame(rafId);
				window.removeEventListener('resize', resize);
			},
		};
	}

	function initSplash() {
		const splash = document.querySelector('[data-splash]');
		if (!(splash instanceof HTMLElement)) return;

		const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		if (sessionStorage.getItem(SEEN_KEY) || reduced) {
			splash.remove();
			return;
		}

		document.body.style.overflow = 'hidden';
		const canvas = splash.querySelector('[data-splash-canvas]');
		const sim = canvas instanceof HTMLCanvasElement ? startShader(canvas) : null;

		let dismissed = false;
		const dismiss = () => {
			if (dismissed) return;
			dismissed = true;
			sessionStorage.setItem(SEEN_KEY, '1');
			document.body.style.overflow = '';
			splash.classList.add('done');
			window.setTimeout(() => {
				sim?.stop();
				splash.remove();
			}, 950);
		};

		// 時序：光譜雲氣播放約 1.7s → 中心白光放大鋪滿約 1.1s → 淡出進入首頁
		window.setTimeout(() => sim?.igniteBloom(), 1700);
		window.setTimeout(dismiss, 2900);
		// 允許點擊快進
		splash.addEventListener('click', () => {
			sim?.igniteBloom();
			window.setTimeout(dismiss, 550);
		});
	}

	document.addEventListener('astro:page-load', initSplash);
</script>
