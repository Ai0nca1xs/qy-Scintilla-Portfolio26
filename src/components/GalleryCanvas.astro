---
// 無限分層畫布 · 互動規則（嚴格遵循）：
// ① 全域畫布平移：游標在視口內移動，整個網格持續向游標的「反方向」平移；
//    以歸一化游標坐標驅動速度，配合逐磚取模回繞 → 四方向無縫無限循環。
// ② 多層次視差：每塊磚由多個堆疊圖層構成（底板 / 編號 / 引文 / 說明文字），
//    各圖層以遞進的深度係數平移，形成塊內 3D 視差。
// ③ 3D 懸停傾斜：懸停時磚依游標在其包圍盒內的相對位置 rotateX / rotateY 傾斜。
// ④ 插值與阻尼：平移、視差、傾斜全部經 lerp 平滑，經 rAF 驅動，帶自然拖尾延遲。
//
// ▍圖片放置規則（多圖橫向瀏覽）：放進 src/assets/gallery/，檔名以磚編號開頭：
//     GAL-001.jpg                → 磚面首圖（自適應比例，不裁切）
//     GAL-001-02-atelier-vue.jpg → 詳情第 2 張（去掉編號的檔名 = 底部圖注）
//     GAL-001-03.jpg             → 詳情第 3 張（無文字則不顯示圖注）
//   點開磚後從左往右滾動瀏覽全部圖片；沒有圖片的磚保持純色佔位卡。
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import { galleryTiles as tiles } from '@/data/gallery';
import { useTranslations, type Lang } from '@/i18n/utils';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// 磚的多圖自動裝載：檔名以編號開頭（不分大小寫），按檔名排序
const galleryImages = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/gallery/*.{jpg,jpeg,png,webp}',
	{ eager: true }
);
const imagesFor = (code: string) =>
	Object.entries(galleryImages)
		.filter(([path]) => {
			const base = (path.split('/').pop() ?? '').toUpperCase();
			return base === `${code.toUpperCase()}` || base.startsWith(`${code.toUpperCase()}.`) || base.startsWith(`${code.toUpperCase()}-`);
		})
		// 排序鍵 = 編號後的尾綴（首圖無尾綴 → 排最前；"-02" "-03" 按數字序）
		.sort(([a], [b]) => {
			const key = (p: string) =>
				(p.split('/').pop() ?? '').replace(/\.[a-z]+$/i, '').slice(code.length) || '-00';
			return key(a).localeCompare(key(b), undefined, { numeric: true });
		})
		.map(([path, mod]) => {
			// 圖注 = 檔名去掉「編號-序號-」前綴（"GAL-001-02-atelier-vue" → "Atelier vue"）
			const base = (path.split('/').pop() ?? '').replace(/\.[a-z]+$/i, '');
			const rest = base
				.slice(code.length)
				.replace(/^-\d+/, '')
				.replace(/^[-_]+/, '')
				.replace(/[-_]+/g, ' ')
				.trim();
			const caption = rest ? rest.charAt(0).toUpperCase() + rest.slice(1) : '';
			return { image: mod.default, caption };
		});

// 基礎單元（design px）：磚散置在 1500×1080 的一格裡，2×2 複製後逐磚回繞
const CELL_W = 1500;
const CELL_H = 1080;

// 每磚固定的視差 ease（0.5–1.0）：同一磚的複製份共享，回繞節奏才能對齊
const easeOf = (i: number) => 0.5 + ((i * 37) % 23) / 46;

// 2×2 平鋪複製
const copies = [
	{ cx: 0, cy: 0 },
	{ cx: 1, cy: 0 },
	{ cx: 0, cy: 1 },
	{ cx: 1, cy: 1 },
];
---

<div class="canvas-viewport" data-canvas-viewport>
	{
		copies.map((copy, ci) =>
			tiles.map((tile, ti) => {
				const imgs = imagesFor(tile.code);
				return (
					<div
						class="canvas-tile"
						data-tile
						data-code={tile.code}
						data-title={tile.title}
						data-matiere={tile.matiere}
						data-date={tile.date}
						data-desc={tile.desc}
						data-quote={tile.quote ?? ''}
						data-bx={tile.x}
						data-by={tile.y}
						data-cx={copy.cx}
						data-cy={copy.cy}
						data-ease={easeOf(ti).toFixed(3)}
						aria-hidden={ci === 0 ? undefined : 'true'}
						style={`width:${tile.w}px; --plate-h:${tile.h}px; --tone:${tile.tone}; --tile-ink:${tile.ink ?? '#f8f9fa'};`}
					>
						<div class="tile-intro">
							{/* ③ 傾斜層：懸停 rotateX/rotateY */}
							<div class="tile-tilt" data-tilt data-cursor-label="VIEW">
								{/* ② 視差層 1：底板；有圖片時高度隨圖片比例自適應（不裁切） */}
								<div class:list={['tile-plate', { 'has-img': imgs.length > 0 }]} data-depth="0.35">
									{imgs.length > 0 && (
										<Image src={imgs[0].image} alt={tile.title} class="tile-img" width={900} />
									)}
									<span class="metadata tile-code" data-depth="0.75">{tile.code}</span>
									{tile.quote && (
										<p class="tile-quote" data-depth="0.55">
											{tile.quote}
										</p>
									)}
								</div>
							</div>
							{/* ② 視差層 2：磚外說明文字（最淺、移動最多）——標題 / 尺寸材質 / 簡介 / 年份 */}
							<div class="tile-caption" data-depth="1">
								<span class="cap-title">{tile.title}</span>
								<span class="cap-line">{tile.matiere}</span>
								<span class="cap-line">{tile.desc}</span>
								<span class="cap-year">{tile.date}</span>
							</div>
						</div>
					</div>
				);
			})
		)
	}
</div>

{/* 詳情滑軌模板：每磚一份（多圖橫向瀏覽的素材，JS 開啟時取用） */}
{
	tiles.map((tile) => {
		const imgs = imagesFor(tile.code);
		return (
			imgs.length > 0 && (
				<template data-slides={tile.code}>
					{imgs.map((it) => (
						<Image src={it.image} alt={it.caption || tile.title} data-caption={it.caption} width={1600} />
					))}
				</template>
			)
		);
	})
}

{/* 沉浸式詳情層：從左往右滾動瀏覽；點空白 / 背景 / Esc 退出 */}
<div class="gallery-detail" data-detail hidden>
	<div class="detail-backdrop" data-detail-backdrop></div>

	<div class="detail-scroller" data-detail-scroller></div>

	{/* 首屏 meta（開啟時移入第一張圖下方，與圖片左對齊） */}
	<div class="detail-meta" data-detail-meta hidden>
		<h2 class="detail-title" data-detail-title></h2>
		<span class="detail-line" data-detail-matiere></span>
		<p class="detail-desc" data-detail-desc></p>
		<span class="detail-year" data-detail-date></span>
	</div>

	{/* 底部信息條：左＝當前圖注，右＝01/07（斜體同字號） */}
	<div class="detail-bar">
		<span class="bar-caption" data-bar-caption></span>
		<span class="bar-counter" data-bar-counter></span>
	</div>

	{/* 輔助箭頭：低調置於兩側 */}
	<button class="detail-nav prev" data-detail-prev aria-label="Previous">‹</button>
	<button class="detail-nav next" data-detail-next aria-label="Next">›</button>

	<button class="detail-close metadata" data-detail-close>Close ✕</button>
</div>

<style define:vars={{ cellW: `${CELL_W}`, cellH: `${CELL_H}` }}>
	/* 視口：全出血撐滿整頁——上緣越過透明 header，開頁即滿屏無白隙 */
	.canvas-viewport {
		position: relative;
		height: calc(100svh + 64px);
		margin-top: -64px;
		margin-inline: calc(var(--gutter) * -1);
		overflow: hidden;
		touch-action: none;
		user-select: none;
		-webkit-user-select: none;
	}

	/* 定位殼：JS 逐幀 translate3d */
	.canvas-tile {
		position: absolute;
		top: 0;
		left: 0;
		will-change: transform;
	}

	/* 入場殼 */
	.tile-intro {
		opacity: 0;
		transform: scale(0.8);
		transition:
			opacity 0.9s var(--ease-develop),
			transform 0.9s var(--ease-develop);
	}
	.tile-intro.in {
		opacity: 1;
		transform: none;
	}

	/* 傾斜殼：透視 + rotateX/Y（JS 驅動） */
	.tile-tilt {
		transform-style: preserve-3d;
		will-change: transform;
		cursor: pointer;
	}

	/* 底板：純色佔位（素材就位後換圖） */
	.tile-plate {
		position: relative;
		height: var(--plate-h);
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		padding: 12px 16px;
		box-sizing: border-box;
		background: var(--tone);
		color: var(--tile-ink);
		overflow: hidden;
		will-change: transform;
	}

	/* 有圖磚：高度隨圖片比例自適應（寬度守磚位，長寬不裁切） */
	.tile-plate.has-img {
		height: auto;
		padding: 0;
		display: block;
		background: none;
	}
	.tile-img {
		display: block;
		width: 100%;
		height: auto;
	}
	.tile-plate.has-img .tile-code {
		position: absolute;
		top: 12px;
		left: 16px;
		color: #ffffff;
		text-shadow: 0 1px 8px rgba(26, 26, 26, 0.5);
	}

	.tile-code {
		position: relative;
		color: inherit;
		opacity: 0.55;
		will-change: transform;
	}

	.tile-quote {
		font-size: 14px;
		font-style: italic;
		line-height: 1.6;
		opacity: 0.92;
		margin: 0;
		will-change: transform;
	}

	/* 磚外說明：mono 10px（≈8pt）四行，自動換行，色階分層 */
	.tile-caption {
		display: flex;
		flex-direction: column;
		gap: 2px;
		margin-top: 8px;
		font-family: var(--font-mono);
		font-size: 10px;
		line-height: 1.5;
		letter-spacing: 0.02em;
		will-change: transform;
	}

	.cap-title {
		font-weight: 700;
		color: var(--text-primary);
	}

	/* 材質 / 簡介 / 年份：Roboto Mono Italic 圖注式 */
	.cap-line {
		color: var(--text-secondary);
		font-style: italic;
	}

	.cap-year {
		color: var(--text-muted);
		font-style: italic;
	}

	/* —— 沉浸式詳情層 —— */
	.gallery-detail {
		position: fixed;
		inset: 0;
		z-index: 800;
		opacity: 0;
		transition: opacity 0.45s var(--ease-develop);
	}
	.gallery-detail.open {
		opacity: 1;
	}
	.gallery-detail[hidden] {
		display: none;
	}

	/* 背景：近乎不透明的白 + 強模糊——畫布退場，只留圖片（沉浸） */
	.detail-backdrop {
		position: absolute;
		inset: 0;
		background: rgba(248, 249, 250, 0.94);
		-webkit-backdrop-filter: blur(28px) saturate(1.2);
		backdrop-filter: blur(28px) saturate(1.2);
	}

	/* 橫向滑軌：從左往右滾動瀏覽，snap 置中，隱藏滾動條 */
	.detail-scroller {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		gap: 7vw;
		padding: 56px max(12vw, var(--gutter)) 88px;
		overflow-x: auto;
		overflow-y: hidden;
		scroll-snap-type: x mandatory;
		scrollbar-width: none;
	}
	.detail-scroller::-webkit-scrollbar {
		display: none;
	}

	/* 幻燈片：漸進入場；非當前張半透明退後（聚焦當前） */
	.gallery-detail :global(.d-slide) {
		flex: 0 0 auto;
		margin: 0;
		display: flex;
		flex-direction: column;
		align-items: flex-start; /* meta / 圖注與圖片左緣對齊 */
		scroll-snap-align: center;
		opacity: 0;
		transform: translateX(36px);
		transition:
			opacity 0.6s var(--ease-develop),
			transform 0.6s var(--ease-develop);
	}
	.gallery-detail :global(.d-slide.in) {
		opacity: 0.32;
		transform: none;
	}
	.gallery-detail :global(.d-slide.in.active) {
		opacity: 1;
	}

	.gallery-detail :global(.d-media img) {
		display: block;
		width: auto;
		height: auto;
		max-height: 62vh;
		max-width: min(78vw, 1100px);
		box-shadow: 0 24px 70px -36px rgba(26, 26, 26, 0.4);
	}

	/* 無圖磚的純色卡 */
	.gallery-detail :global(.d-card) {
		width: min(560px, 78vw);
		aspect-ratio: 4 / 3;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		padding: 24px;
		box-sizing: border-box;
		background: var(--tone, #1a1a1a);
		color: var(--tile-ink, #f8f9fa);
		box-shadow: 0 24px 70px -36px rgba(26, 26, 26, 0.4);
	}
	.gallery-detail :global(.d-card-code) {
		color: inherit;
		opacity: 0.55;
	}
	.gallery-detail :global(.d-card-quote) {
		font-size: 18px;
		font-style: italic;
		line-height: 1.5;
		margin: 0;
		opacity: 0.92;
	}

	/* 首張下方的四行說明：與圖片左對齊 */
	.detail-meta {
		margin-top: 16px;
		max-width: min(78vw, 560px);
		text-align: left;
		font-family: var(--font-mono);
	}
	.detail-meta > * {
		opacity: 0;
		transform: translateY(10px);
	}
	.gallery-detail.open .detail-meta > * {
		animation: meta-in 0.55s var(--ease-develop) forwards;
	}
	.gallery-detail.open .detail-title {
		animation-delay: 0.15s;
	}
	.gallery-detail.open .detail-line {
		animation-delay: 0.22s;
	}
	.gallery-detail.open .detail-desc {
		animation-delay: 0.3s;
	}
	.gallery-detail.open .detail-year {
		animation-delay: 0.36s;
	}

	@keyframes meta-in {
		to {
			opacity: 1;
			transform: none;
		}
	}

	.detail-title {
		font-size: clamp(1.4rem, 3vw, 2rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin: 0 0 6px;
	}
	.detail-line {
		display: block;
		font-size: 12px;
		color: var(--text-secondary);
		margin-bottom: 6px;
	}
	.detail-desc {
		font-size: 12px;
		line-height: 22px;
		color: var(--text-secondary);
		max-width: 52ch;
		margin: 0 0 6px;
	}
	.detail-year {
		display: block;
		font-size: 12px;
		color: var(--text-muted);
	}

	/* 底部信息條：左圖注 / 右計數（同字號，計數斜體） */
	.detail-bar {
		position: absolute;
		left: max(12vw, var(--gutter));
		right: max(12vw, var(--gutter));
		bottom: 24px;
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 24px;
		pointer-events: none;
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.06em;
	}
	.bar-caption {
		color: var(--text-secondary);
	}
	.bar-counter {
		font-style: italic;
		color: var(--text-muted);
	}

	/* 輔助箭頭：低調的兩側符號 */
	.detail-nav {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		width: 44px;
		height: 44px;
		display: flex;
		align-items: center;
		justify-content: center;
		border: none;
		background: none;
		font-family: var(--font-mono);
		font-size: 26px;
		line-height: 1;
		color: var(--color-ink);
		opacity: 0.22;
		cursor: pointer;
		transition: opacity 0.3s ease;
		z-index: 2;
	}
	.detail-nav:hover {
		opacity: 0.7;
	}
	.detail-nav.prev {
		left: 10px;
	}
	.detail-nav.next {
		right: 10px;
	}
	.gallery-detail[data-single='1'] .detail-nav,
	.gallery-detail[data-single='1'] .bar-counter {
		display: none;
	}

	.detail-close {
		position: absolute;
		top: 16px;
		right: var(--gutter);
		display: inline-flex;
		align-items: center;
		height: var(--btn-height); /* 全站按鈕統一高度 */
		padding: 0;
		border: none;
		background: none;
		cursor: pointer;
		text-decoration: underline;
		text-underline-offset: 6px;
		transition: color 0.3s var(--ease-oxide);
		z-index: 2;
	}
	.detail-close:hover {
		color: var(--color-accent);
	}

	@media (prefers-reduced-motion: reduce) {
		.tile-intro,
		.gallery-detail,
		.gallery-detail :global(.d-slide),
		.gallery-detail.open .detail-meta > * {
			transition: none !important;
			animation: none !important;
		}
		.tile-intro,
		.gallery-detail :global(.d-slide) {
			opacity: 1;
			transform: none;
		}
		.gallery-detail.open .detail-meta > * {
			opacity: 1;
			transform: none;
		}
	}
</style>

<script>
	// 互動核心：全域反向平移（速度場）＋逐磚回繞＋塊內多層視差＋3D 懸停傾斜，全部 lerp 阻尼。
	function initInfiniteCanvas() {
		const viewport = document.querySelector<HTMLElement>('[data-canvas-viewport]');
		if (!viewport) return;
		const els = Array.from(viewport.querySelectorAll<HTMLElement>('[data-tile]'));
		if (!els.length) return;

		const styles = getComputedStyle(viewport);
		const DESIGN_W = parseFloat(styles.getPropertyValue('--cellW')) || 1500;
		const DESIGN_H = parseFloat(styles.getPropertyValue('--cellH')) || 1080;
		const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		const finePointer = window.matchMedia('(pointer: fine)').matches;

		type Item = {
			el: HTMLElement;
			tilt: HTMLElement | null;
			layers: { el: HTMLElement; depth: number }[];
			bx: number;
			by: number;
			cx: number;
			cy: number;
			w: number;
			h: number;
			ease: number;
			rx: number; // 當前傾斜（lerp 狀態）
			ry: number;
			trx: number; // 目標傾斜
			try: number;
		};
		const items: Item[] = els.map((el) => ({
			el,
			tilt: el.querySelector<HTMLElement>('[data-tilt]'),
			layers: Array.from(el.querySelectorAll<HTMLElement>('[data-depth]')).map((layer) => ({
				el: layer,
				depth: parseFloat(layer.dataset.depth ?? '1'),
			})),
			bx: parseFloat(el.dataset.bx ?? '0'),
			by: parseFloat(el.dataset.by ?? '0'),
			cx: parseInt(el.dataset.cx ?? '0', 10),
			cy: parseInt(el.dataset.cy ?? '0', 10),
			w: el.offsetWidth,
			h: el.offsetHeight,
			ease: reduced ? 1 : parseFloat(el.dataset.ease ?? '1'),
			rx: 0,
			ry: 0,
			trx: 0,
			try: 0,
		}));
		const maxW = Math.max(...items.map((i) => i.w)) + 40;
		const maxH = Math.max(...items.map((i) => i.h)) + 60;

		// 平鋪單元隨視口放大（位置等比擴散、磚尺寸不變），2×2 覆蓋任何屏幕
		let cellW = DESIGN_W;
		let cellH = DESIGN_H;
		let posScaleX = 1;
		let posScaleY = 1;
		const measure = () => {
			cellW = Math.max(DESIGN_W, (viewport.clientWidth + maxW) / 2 + 40);
			cellH = Math.max(DESIGN_H, (viewport.clientHeight + maxH) / 2 + 40);
			posScaleX = cellW / DESIGN_W;
			posScaleY = cellH / DESIGN_H;
		};
		measure();
		window.addEventListener('resize', measure);

		// —— 狀態：全域偏移 + 歸一化游標（lerp 前後兩份）——
		let ox = -cellW * 0.3;
		let oy = -cellH * 0.2;
		let nxT = 0.5; // 歸一化游標目標（0–1）
		let nyT = 0.5;
		let nx = 0.5; // lerp 後的游標
		let ny = 0.5;
		let inside = false;
		let paused = false;
		let hovered: Item | null = null;
		let rafId = 0;

		// 觸屏回退：保留拖拽平移
		let dragging = false;
		let lastX = 0;
		let lastY = 0;
		let moved = 0;

		const MAX_SPEED = 5; // 游標貼邊時的每幀平移速度（px）
		const PARALLAX = 26; // 塊內視差最大位移（px）
		const TILT = 9; // 最大傾斜角（deg）

		const mod = (v: number, size: number) => ((v % size) + size) % size;

		const render = () => {
			const totalW = cellW * 2;
			const totalH = cellH * 2;
			const lpx = (nx - 0.5) * PARALLAX;
			const lpy = (ny - 0.5) * PARALLAX * 0.7;
			for (const it of items) {
				const x = it.bx * posScaleX + it.cx * cellW + ox * it.ease;
				const y = it.by * posScaleY + it.cy * cellH + oy * it.ease;
				const wx = mod(x + maxW, totalW) - maxW;
				const wy = mod(y + maxH, totalH) - maxH;
				it.el.style.transform = `translate3d(${wx.toFixed(2)}px, ${wy.toFixed(2)}px, 0)`;

				// 塊內多層視差：各層依深度係數反向移動
				if (!reduced) {
					for (const layer of it.layers) {
						layer.el.style.transform = `translate3d(${(-lpx * layer.depth).toFixed(2)}px, ${(-lpy * layer.depth).toFixed(2)}px, 0)`;
					}
				}

				// 3D 傾斜 lerp
				it.rx += (it.trx - it.rx) * 0.12;
				it.ry += (it.try - it.ry) * 0.12;
				if (it.tilt) {
					if (Math.abs(it.rx) > 0.01 || Math.abs(it.ry) > 0.01) {
						it.tilt.style.transform = `perspective(720px) rotateX(${it.rx.toFixed(2)}deg) rotateY(${it.ry.toFixed(2)}deg)`;
					} else if (it.tilt.style.transform) {
						it.tilt.style.transform = '';
					}
				}
			}
		};

		const loop = () => {
			rafId = 0;
			if (paused) return;
			// 游標 lerp（阻尼拖尾）
			nx += (nxT - nx) * 0.06;
			ny += (nyT - ny) * 0.06;
			// ① 全域反向平移：游標偏離中心 → 網格持續向反方向滑動
			if (!reduced && finePointer) {
				ox -= (nx - 0.5) * MAX_SPEED;
				oy -= (ny - 0.5) * MAX_SPEED * 0.72;
			}
			render();
			const tiltBusy = items.some(
				(it) => Math.abs(it.trx - it.rx) > 0.02 || Math.abs(it.try - it.ry) > 0.02
			);
			const panBusy = inside || Math.abs(nx - 0.5) > 0.004 || Math.abs(ny - 0.5) > 0.004;
			if (panBusy || tiltBusy || dragging) wake();
		};
		const wake = () => {
			if (!rafId && !paused) rafId = requestAnimationFrame(loop);
		};

		// —— 游標追蹤：歸一化視口坐標 + 塊內相對位置 → 傾斜目標 ——
		viewport.addEventListener('pointerenter', (e) => {
			if (e.pointerType !== 'mouse') return;
			inside = true;
			wake();
		});
		viewport.addEventListener('pointermove', (e) => {
			if (e.pointerType === 'mouse') {
				const r = viewport.getBoundingClientRect();
				nxT = Math.min(1, Math.max(0, (e.clientX - r.left) / r.width));
				nyT = Math.min(1, Math.max(0, (e.clientY - r.top) / r.height));
				// ③ 傾斜：找到游標下的磚，依包圍盒內相對位置定目標角
				const tiltEl = (e.target as Element)?.closest?.('[data-tilt]');
				const tileEl = tiltEl?.closest<HTMLElement>('[data-tile]');
				const it = items.find((i) => i.el === tileEl) ?? null;
				if (hovered && hovered !== it) {
					hovered.trx = 0;
					hovered.try = 0;
				}
				hovered = it;
				if (it && !reduced) {
					const pr = (tiltEl as HTMLElement).getBoundingClientRect();
					const relX = (e.clientX - pr.left) / pr.width;
					const relY = (e.clientY - pr.top) / pr.height;
					it.trx = (0.5 - relY) * TILT;
					it.try = (relX - 0.5) * TILT;
				}
				wake();
				return;
			}
			// 觸屏：拖拽平移
			if (!dragging) return;
			const dx = e.clientX - lastX;
			const dy = e.clientY - lastY;
			lastX = e.clientX;
			lastY = e.clientY;
			moved += Math.abs(dx) + Math.abs(dy);
			ox += dx;
			oy += dy;
			render();
		});
		viewport.addEventListener('pointerleave', (e) => {
			if (e.pointerType !== 'mouse') return;
			inside = false;
			nxT = 0.5; // 游標離開 → 平移速度緩緩歸零
			nyT = 0.5;
			if (hovered) {
				hovered.trx = 0;
				hovered.try = 0;
				hovered = null;
			}
			wake();
		});
		viewport.addEventListener('pointerdown', (e) => {
			if (e.pointerType === 'mouse' || paused) return;
			dragging = true;
			moved = 0;
			lastX = e.clientX;
			lastY = e.clientY;
		});
		const release = () => {
			dragging = false;
		};
		viewport.addEventListener('pointerup', release);
		viewport.addEventListener('pointercancel', release);

		// —— 開場：可見磚由畫面中心向外 stagger 入場 ——
		render();
		const vw = viewport.clientWidth;
		const vh = viewport.clientHeight;
		const vr = viewport.getBoundingClientRect();
		const byDistance = items
			.map((it) => {
				const r = it.el.getBoundingClientRect();
				const dx = r.left - vr.left + r.width / 2 - vw / 2;
				const dy = r.top - vr.top + r.height / 2 - vh / 2;
				return { it, d: Math.hypot(dx, dy) };
			})
			.sort((a, b) => a.d - b.d);
		byDistance.forEach(({ it }, i) => {
			const intro = it.el.querySelector<HTMLElement>('.tile-intro');
			if (intro) intro.style.transitionDelay = `${Math.min(i * 45, 900)}ms`;
		});
		requestAnimationFrame(() => {
			viewport.querySelectorAll<HTMLElement>('.tile-intro').forEach((intro) => intro.classList.add('in'));
		});
		window.setTimeout(() => {
			viewport.querySelectorAll<HTMLElement>('.tile-intro').forEach((intro) => {
				intro.style.transitionDelay = '';
			});
		}, 1400);

		// —— 沉浸式詳情：橫向滾動瀏覽多圖 ——
		const detail = document.querySelector<HTMLElement>('[data-detail]');
		const scroller = document.querySelector<HTMLElement>('[data-detail-scroller]');
		const backdrop = document.querySelector<HTMLElement>('[data-detail-backdrop]');
		const closeBtn = document.querySelector<HTMLElement>('[data-detail-close]');
		const prevBtn = document.querySelector<HTMLElement>('[data-detail-prev]');
		const nextBtn = document.querySelector<HTMLElement>('[data-detail-next]');
		const metaBox = document.querySelector<HTMLElement>('[data-detail-meta]');
		const barCaption = document.querySelector<HTMLElement>('[data-bar-caption]');
		const barCounter = document.querySelector<HTMLElement>('[data-bar-counter]');
		const elTitle = document.querySelector<HTMLElement>('[data-detail-title]');
		const elMatiere = document.querySelector<HTMLElement>('[data-detail-matiere]');
		const elDate = document.querySelector<HTMLElement>('[data-detail-date]');
		const elDesc = document.querySelector<HTMLElement>('[data-detail-desc]');

		let open = false;
		let slides: HTMLElement[] = [];
		let captions: string[] = [];
		let active = -1;
		let scrollRaf = 0;

		const pad2 = (n: number) => String(n).padStart(2, '0');

		// 依滑軌中心找當前張：更新計數、圖注與聚焦態
		const updateActive = () => {
			scrollRaf = 0;
			if (!scroller || !slides.length) return;
			const center = scroller.scrollLeft + scroller.clientWidth / 2;
			let best = 0;
			let bestD = Infinity;
			slides.forEach((s, i) => {
				const c = s.offsetLeft + s.offsetWidth / 2;
				const d = Math.abs(c - center);
				if (d < bestD) {
					bestD = d;
					best = i;
				}
			});
			if (best !== active) {
				active = best;
				slides.forEach((s, i) => s.classList.toggle('active', i === active));
				if (barCounter) barCounter.textContent = `${pad2(active + 1)}/${pad2(slides.length)}`;
				if (barCaption) barCaption.textContent = captions[active] ?? '';
			}
		};
		const queueUpdate = () => {
			if (!scrollRaf) scrollRaf = requestAnimationFrame(updateActive);
		};

		const openTile = (tile: HTMLElement) => {
			if (!detail || !scroller || !metaBox || open) return;
			open = true;
			paused = true;
			cancelAnimationFrame(rafId);
			rafId = 0;

			const d = tile.dataset;
			if (elTitle) elTitle.textContent = d.title ?? '';
			if (elMatiere) elMatiere.textContent = d.matiere ?? '';
			if (elDate) elDate.textContent = d.date ?? '';
			if (elDesc) elDesc.textContent = d.desc ?? '';

			// 組裝幻燈片
			scroller.textContent = '';
			captions = [];
			const frag = document.createDocumentFragment();
			const tpl = document.querySelector<HTMLTemplateElement>(
				`template[data-slides="${d.code}"]`
			);
			const makeSlide = () => {
				const slide = document.createElement('figure');
				slide.className = 'd-slide';
				return slide;
			};

			if (tpl && tpl.content.querySelector('img')) {
				Array.from(tpl.content.querySelectorAll('img')).forEach((imgNode, i) => {
					const slide = makeSlide();
					const media = document.createElement('div');
					media.className = 'd-media';
					const img = imgNode.cloneNode(true) as HTMLImageElement;
					media.appendChild(img);
					slide.appendChild(media);
					captions.push(img.dataset.caption ?? '');
					if (i === 0) {
						metaBox.hidden = false;
						slide.appendChild(metaBox); // meta 移入首張圖下方 → 與圖片左緣對齊
					}
					frag.appendChild(slide);
				});
			} else {
				// 無圖磚：純色卡 + meta
				const slide = makeSlide();
				const media = document.createElement('div');
				media.className = 'd-media';
				const cardEl = document.createElement('div');
				cardEl.className = 'd-card';
				cardEl.style.setProperty('--tone', tile.style.getPropertyValue('--tone'));
				cardEl.style.setProperty('--tile-ink', tile.style.getPropertyValue('--tile-ink'));
				const codeSpan = document.createElement('span');
				codeSpan.className = 'metadata d-card-code';
				codeSpan.textContent = d.code ?? '';
				const quoteP = document.createElement('p');
				quoteP.className = 'd-card-quote';
				quoteP.textContent = d.quote ?? '';
				cardEl.append(codeSpan, quoteP);
				media.appendChild(cardEl);
				slide.appendChild(media);
				metaBox.hidden = false;
				slide.appendChild(metaBox);
				captions.push('');
				frag.appendChild(slide);
			}

			scroller.appendChild(frag);
			slides = Array.from(scroller.querySelectorAll<HTMLElement>('.d-slide'));
			detail.dataset.single = slides.length <= 1 ? '1' : '0';
			active = -1;
			scroller.scrollLeft = 0;

			detail.hidden = false;
			requestAnimationFrame(() => {
				detail.classList.add('open');
				// 圖片漸進入場（stagger），落定後解除延遲
				slides.forEach((s, i) => {
					s.style.transitionDelay = `${Math.min(i * 90, 540)}ms`;
					s.classList.add('in');
				});
				window.setTimeout(() => slides.forEach((s) => (s.style.transitionDelay = '')), 1200);
				updateActive();
			});
		};

		const closeTile = () => {
			if (!detail || !scroller || !metaBox || !open) return;
			detail.classList.remove('open');
			window.setTimeout(() => {
				detail.hidden = true;
				// meta 移回根節點待用
				metaBox.hidden = true;
				detail.appendChild(metaBox);
				scroller.textContent = '';
				slides = [];
				open = false;
				paused = false;
				wake();
			}, 460);
		};

		const goTo = (i: number) => {
			const target = slides[Math.max(0, Math.min(slides.length - 1, i))];
			target?.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
		};

		viewport.addEventListener('click', (e) => {
			if (moved > 6) return; // 觸屏拖拽不觸發點擊
			const tile = (e.target as Element)?.closest<HTMLElement>('[data-tile]');
			if (!tile) return;
			openTile(tile);
		});

		// 滾輪 → 橫向滾動（從左往右瀏覽）
		scroller?.addEventListener(
			'wheel',
			(e) => {
				e.preventDefault();
				scroller.scrollLeft += e.deltaY + e.deltaX;
			},
			{ passive: false }
		);
		scroller?.addEventListener('scroll', queueUpdate, { passive: true });

		// 點擊空白處退出（圖片 / 說明 / 按鈕之外）
		scroller?.addEventListener('click', (e) => {
			const t = e.target as Element;
			if (t === scroller || t.classList?.contains('d-slide')) closeTile();
		});
		backdrop?.addEventListener('click', closeTile);
		closeBtn?.addEventListener('click', closeTile);
		prevBtn?.addEventListener('click', () => goTo(active - 1));
		nextBtn?.addEventListener('click', () => goTo(active + 1));
		window.addEventListener('keydown', (e) => {
			if (!open) return;
			if (e.key === 'Escape') closeTile();
			if (e.key === 'ArrowRight') goTo(active + 1);
			if (e.key === 'ArrowLeft') goTo(active - 1);
		});

		wake();

		document.addEventListener(
			'astro:before-swap',
			() => {
				cancelAnimationFrame(rafId);
				cancelAnimationFrame(scrollRaf);
				window.removeEventListener('resize', measure);
			},
			{ once: true }
		);
	}

	document.addEventListener('astro:page-load', initInfiniteCanvas);
</script>
