---
---
{/* transition:persist 讓游標元素在頁面轉場時保留同一個 DOM 節點，事件監聽不會失效 */}
<canvas class="cursor-trail" transition:persist="cursor-trail" aria-hidden="true"></canvas>
<div class="cursor" transition:persist="cursor" aria-hidden="true"></div>
<span class="cursor-label metadata" transition:persist="cursor-label" aria-hidden="true"></span>

<style is:global>
	/* 只在 JS 確認啟用自訂游標後才全面隱藏系統游標（含連結、按鈕、文字光標），
	   腳本失效時仍有系統游標可用 */
	html.has-custom-cursor,
	html.has-custom-cursor * {
		cursor: none !important;
	}
</style>

<style>
	/* 流線拖尾畫布：鋪滿視口，畫在游標點之下 */
	.cursor-trail {
		position: fixed;
		inset: 0;
		width: 100vw;
		height: 100vh;
		z-index: 9997;
		pointer-events: none;
	}

	/* 游標本體：主題色圓點（筆尖） */
	.cursor {
		width: 8px;
		height: 8px;
		background-color: var(--color-accent);
		border: 1.5px solid transparent;
		border-radius: 50%;
		position: fixed;
		left: 0;
		top: 0;
		pointer-events: none; /* 絕對必要：讓游標穿透，不阻擋下層點擊 */
		z-index: 9999;
		box-shadow: 0 0 10px rgba(255, 0, 72, 0.55);
		opacity: 0; /* 初始隱藏，偵測到指針移動才顯示 */
		transition:
			opacity 0.3s ease,
			background-color 0.25s ease,
			border-color 0.25s ease;
		will-change: transform;
	}

	/* 模式：懸停可點元素時變成主題色空心圓環 */
	.cursor[data-mode='link'] {
		background-color: transparent;
		border-color: var(--color-accent);
	}

	/* 游標旁的標本標籤：懸停在作品上時顯示動作提示（如 VIEW） */
	.cursor-label {
		position: fixed;
		left: 0;
		top: 0;
		z-index: 9998;
		pointer-events: none;
		padding: 3px 8px;
		background: rgba(248, 249, 250, 0.92);
		box-shadow: 0 2px 12px -4px rgba(26, 26, 26, 0.25);
		color: var(--color-ink);
		opacity: 0;
		transition: opacity 0.25s ease;
		will-change: transform;
	}
</style>

<script>
	// 鋼筆流線游標：主題色圓點作筆尖（零延遲貼住指針），身後拖一條彈簧物理流線。
	// 技法取自 Ksenia Kondrashova「satisfying curly cursor」——一串點各以彈簧＋阻尼
	// 追隨前一點，指針事件只更新「目標座標」，拖尾幾何每幀由物理積分生成（與鼠標
	// 採樣率解耦）；再以二次貝塞爾穿過相鄰中點，得到幀同步、連續順滑、且丟幀時能
	// 自我平滑（彈簧插值補洞而非露出斷點）的筆鋒線。這正是「移動不順滑」的根治：
	// 舊版把不等距的原始鼠標採樣點直接連直線，即使 60fps 也顯得一頓一頓。
	// 點擊時保留一簇火花（速度線碎屑）作反饋。
	const cursor = document.querySelector('.cursor');
	const label = document.querySelector('.cursor-label');
	const canvas = document.querySelector('.cursor-trail');

	if (
		cursor instanceof HTMLElement &&
		canvas instanceof HTMLCanvasElement &&
		window.matchMedia('(pointer: fine)').matches
	) {
		const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		const ctx = canvas.getContext('2d');
		const accent =
			getComputedStyle(document.documentElement).getPropertyValue('--color-accent').trim() ||
			'#ff0048';
		// 火花色板：主題色 + 玫瑰 / 琥珀 / 淡粉
		const SPARK_COLORS = [accent, '#ffaad4', '#ffbe0b', '#fdc5f5'];

		// 拖尾是運動中的細線，1.5x 解析度肉眼無差，成本省近一半
		const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
		const resize = () => {
			canvas.width = Math.floor(window.innerWidth * dpr);
			canvas.height = Math.floor(window.innerHeight * dpr);
		};
		resize();
		window.addEventListener('resize', resize);

		let targetX = -100; // 指針目標（筆尖零延遲貼此）
		let targetY = -100;
		let scale = 1;
		let targetScale = 1;
		let hoveringLink = false;
		let pressing = false;
		let rafId = 0;
		let visible = false;

		// —— 彈簧鏈拖尾 ——：POINTS 個節點依次追前一點；頭端粗、尾端漸細
		type TrailNode = { x: number; y: number; dx: number; dy: number };
		const POINTS = 24;
		const SPRING = 0.42; // 彈簧剛度：越大越貼、越小越飄
		const FRICTION = 0.48; // 阻尼：越小越靈動，越大越黏滯
		const WIDTH = 0.16; // 線寬係數 WIDTH*(POINTS-i)*dpr：筆尖 ~3.8px 收到髮絲
		const trail: TrailNode[] = new Array(POINTS);
		for (let i = 0; i < POINTS; i++) trail[i] = { x: -100, y: -100, dx: 0, dy: 0 };
		const collapseTrail = (px: number, py: number) => {
			for (const p of trail) {
				p.x = px;
				p.y = py;
				p.dx = 0;
				p.dy = 0;
			}
		};

		// —— 點擊火花 ——：速度線碎屑，帶阻尼與微重力（點擊反饋保留）
		type Spark = {
			x: number;
			y: number;
			vx: number;
			vy: number;
			age: number;
			life: number;
			color: string;
		};
		let sparks: Spark[] = [];
		let lastFrame = 0;

		const spawnBurst = (bx: number, by: number) => {
			const count = 12;
			for (let i = 0; i < count; i++) {
				const ang = (i / count) * Math.PI * 2 + Math.random() * 0.6;
				const speed = 2.2 + Math.random() * 4.2;
				sparks.push({
					x: bx,
					y: by,
					vx: Math.cos(ang) * speed,
					vy: Math.sin(ang) * speed,
					age: 0,
					life: 380 + Math.random() * 320,
					color: SPARK_COLORS[Math.floor(Math.random() * SPARK_COLORS.length)],
				});
			}
		};

		const paint = (dt: number) => {
			if (!ctx) return false;
			ctx.clearRect(0, 0, canvas.width, canvas.height);

			// 彈簧鏈積分：trail[0] 以較弱彈簧追指針，其餘各自追前一節點
			let moving = false;
			for (let i = 0; i < POINTS; i++) {
				const p = trail[i];
				const prevX = i === 0 ? targetX : trail[i - 1].x;
				const prevY = i === 0 ? targetY : trail[i - 1].y;
				const k = i === 0 ? SPRING * 0.4 : SPRING;
				p.dx = (p.dx + (prevX - p.x) * k) * FRICTION;
				p.dy = (p.dy + (prevY - p.y) * k) * FRICTION;
				p.x += p.dx;
				p.y += p.dy;
				if (Math.abs(p.dx) + Math.abs(p.dy) > 0.05) moving = true;
			}

			// 繪筆鋒線：自筆尖（指針）起，二次貝塞爾穿過相鄰節點中點，逐段收窄
			if (visible) {
				ctx.lineCap = 'round';
				ctx.lineJoin = 'round';
				ctx.strokeStyle = accent;
				ctx.globalAlpha = 1;
				ctx.beginPath();
				ctx.moveTo(targetX * dpr, targetY * dpr);
				for (let i = 0; i < POINTS - 1; i++) {
					const xc = 0.5 * (trail[i].x + trail[i + 1].x) * dpr;
					const yc = 0.5 * (trail[i].y + trail[i + 1].y) * dpr;
					ctx.quadraticCurveTo(trail[i].x * dpr, trail[i].y * dpr, xc, yc);
					ctx.lineWidth = WIDTH * (POINTS - i) * dpr;
					ctx.stroke();
				}
				ctx.lineTo(trail[POINTS - 1].x * dpr, trail[POINTS - 1].y * dpr);
				ctx.stroke();
			}

			// 火花（點擊效果保留）：速度線碎屑
			let sparksAlive = false;
			if (sparks.length) {
				const step = dt / 16.7;
				ctx.lineWidth = 1.6 * dpr;
				for (const s of sparks) {
					s.age += dt;
					s.x += s.vx * step;
					s.y += s.vy * step;
					s.vx *= 0.94;
					s.vy = s.vy * 0.94 + 0.05 * step;
					const kk = 1 - s.age / s.life;
					if (kk <= 0) continue;
					ctx.strokeStyle = s.color;
					ctx.globalAlpha = Math.max(0, kk);
					ctx.beginPath();
					ctx.moveTo(s.x * dpr, s.y * dpr);
					ctx.lineTo((s.x - s.vx * 2.4) * dpr, (s.y - s.vy * 2.4) * dpr);
					ctx.stroke();
				}
				ctx.globalAlpha = 1;
				sparks = sparks.filter((s) => s.age < s.life);
				sparksAlive = sparks.length > 0;
			}

			return moving || sparksAlive;
		};

		const loop = (now: number) => {
			const dt = lastFrame ? Math.min(48, now - lastFrame) : 16.7;
			lastFrame = now;

			// 筆尖零延遲貼住指針（拖尾負責「流」的感覺）；只有縮放做插值
			scale += (targetScale - scale) * 0.18;
			cursor.style.transform = `translate3d(${targetX - 4}px, ${targetY - 4}px, 0) scale(${scale.toFixed(3)})`;
			if (label instanceof HTMLElement) {
				label.style.transform = `translate3d(${targetX + 18}px, ${targetY + 18}px, 0)`;
			}

			const busy = reduced ? false : paint(dt);
			const scaleSettled = Math.abs(targetScale - scale) < 0.01;

			// 全部安定（拖尾收攏、火花散盡、縮放到位）才停機；下次指針事件喚醒
			if (!busy && scaleSettled) {
				rafId = 0;
				lastFrame = 0;
			} else {
				rafId = requestAnimationFrame(loop);
			}
		};

		const wake = () => {
			if (!rafId) rafId = requestAnimationFrame(loop);
		};

		const updateScale = () => {
			targetScale = pressing ? 2.2 : hoveringLink ? 1.9 : 1;
			wake();
		};

		window.addEventListener(
			'pointermove',
			(e) => {
				const jx = e.clientX - targetX;
				const jy = e.clientY - targetY;
				targetX = e.clientX;
				targetY = e.clientY;
				if (!visible) {
					visible = true;
					collapseTrail(targetX, targetY);
					document.documentElement.classList.add('has-custom-cursor');
					cursor.style.opacity = '1';
				} else if (jx * jx + jy * jy > 260 * 260) {
					// 指針大跳（重入視口／瞬移）：收攏拖尾，避免橫掃整屏的長線
					collapseTrail(targetX, targetY);
				}
				wake();
			},
			{ passive: true }
		);

		window.addEventListener('pointerdown', (e) => {
			pressing = true;
			updateScale();
			if (!reduced) spawnBurst(e.clientX, e.clientY);
			wake();
		});

		window.addEventListener('pointerup', () => {
			pressing = false;
			updateScale();
		});

		// 懸停在可點擊元素上時：游標放大並切換為空心圓環；
		// 帶 data-cursor-label 的元素會在游標旁顯示動作標籤（如 VIEW / FLIP / DRAG）
		document.addEventListener('mouseover', (e) => {
			const el = e.target instanceof Element ? e.target : null;
			hoveringLink = !!el?.closest('a, button, [role="button"]');
			updateScale();
			cursor.dataset.mode = hoveringLink ? 'link' : 'dot';

			if (label instanceof HTMLElement) {
				const tagged = el?.closest('[data-cursor-label]');
				if (tagged) {
					label.textContent = tagged.getAttribute('data-cursor-label');
					label.style.opacity = '1';
				} else {
					label.style.opacity = '0';
				}
			}
		});
	}
</script>
