---
---
{/* transition:persist 讓游標元素在頁面轉場時保留同一個 DOM 節點，事件監聽不會失效 */}
<div class="cursor" transition:persist="cursor" aria-hidden="true"></div>
<span class="cursor-label metadata" transition:persist="cursor-label" aria-hidden="true"></span>

<style is:global>
	/* 只在 JS 確認啟用自訂游標後才隱藏系統游標，腳本失效時仍有游標可用 */
	html.has-custom-cursor,
	html.has-custom-cursor a,
	html.has-custom-cursor button {
		cursor: none;
	}
</style>

<style>
	.cursor {
		width: 10px;
		height: 10px;
		background-color: white; /* 設為白色以完美反轉所有背景 */
		border-radius: 50%;
		position: fixed;
		left: 0;
		top: 0;
		pointer-events: none; /* 絕對必要：讓游標穿透，不阻擋下層點擊 */
		z-index: 9999;
		mix-blend-mode: difference; /* 反轉色核心屬性 */
		opacity: 0; /* 初始隱藏，偵測到指針移動才顯示 */
		transition: opacity 0.3s ease;
		will-change: transform;
	}

	/* 游標旁的標本標籤：懸停在作品上時顯示動作提示（如 VIEW） */
	.cursor-label {
		position: fixed;
		left: 0;
		top: 0;
		z-index: 9998;
		pointer-events: none;
		padding: 3px 8px;
		background: rgba(248, 249, 250, 0.88);
		border: 1px solid var(--color-line);
		color: var(--color-ink);
		opacity: 0;
		transition: opacity 0.25s ease;
		will-change: transform;
	}
</style>

<script>
	// 效能要點：位置與縮放全部走 transform（合成器處理，不觸發重排），
	// 並用 rAF + 線性插值做柔性跟隨；游標靜止後自動停掉動畫循環。
	const cursor = document.querySelector('.cursor');
	const label = document.querySelector('.cursor-label');

	if (cursor instanceof HTMLElement && window.matchMedia('(pointer: fine)').matches) {
		let x = -100;
		let y = -100;
		let targetX = -100;
		let targetY = -100;
		let scale = 1;
		let targetScale = 1;
		let hoveringLink = false;
		let pressing = false;
		let rafId = 0;
		let visible = false;

		const loop = () => {
			x += (targetX - x) * 0.25;
			y += (targetY - y) * 0.25;
			scale += (targetScale - scale) * 0.18;
			cursor.style.transform = `translate3d(${x - 5}px, ${y - 5}px, 0) scale(${scale.toFixed(3)})`;
			if (label instanceof HTMLElement) {
				label.style.transform = `translate3d(${x + 18}px, ${y + 18}px, 0)`;
			}

			const settled =
				Math.abs(targetX - x) < 0.1 &&
				Math.abs(targetY - y) < 0.1 &&
				Math.abs(targetScale - scale) < 0.01;

			rafId = settled ? 0 : requestAnimationFrame(loop);
		};

		const wake = () => {
			if (!rafId) rafId = requestAnimationFrame(loop);
		};

		const updateScale = () => {
			targetScale = pressing ? 2.4 : hoveringLink ? 1.8 : 1;
			wake();
		};

		window.addEventListener(
			'pointermove',
			(e) => {
				targetX = e.clientX;
				targetY = e.clientY;
				if (!visible) {
					visible = true;
					x = targetX;
					y = targetY;
					document.documentElement.classList.add('has-custom-cursor');
					cursor.style.opacity = '1';
				}
				wake();
			},
			{ passive: true }
		);

		window.addEventListener('pointerdown', () => {
			pressing = true;
			updateScale();
		});

		window.addEventListener('pointerup', () => {
			pressing = false;
			updateScale();
		});

		// 懸停在可點擊元素上時游標放大，作為統一的互動回饋；
		// 帶 data-cursor-label 的元素會在游標旁顯示動作標籤（如 VIEW）
		document.addEventListener('mouseover', (e) => {
			const el = e.target instanceof Element ? e.target : null;
			hoveringLink = !!el?.closest('a, button');
			updateScale();

			if (label instanceof HTMLElement) {
				const tagged = el?.closest('[data-cursor-label]');
				if (tagged) {
					label.textContent = tagged.getAttribute('data-cursor-label');
					label.style.opacity = '1';
				} else {
					label.style.opacity = '0';
				}
			}
		});
	}
</script>
