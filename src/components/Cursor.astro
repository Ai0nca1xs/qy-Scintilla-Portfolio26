---
---
{/* transition:persist 讓游標元素在頁面轉場時保留同一個 DOM 節點，事件監聽不會失效 */}
<canvas class="cursor-trail" transition:persist="cursor-trail" aria-hidden="true"></canvas>
<div class="cursor" transition:persist="cursor" aria-hidden="true"></div>
<span class="cursor-label metadata" transition:persist="cursor-label" aria-hidden="true"></span>

<style is:global>
	/* 只在 JS 確認啟用自訂游標後才全面隱藏系統游標（含連結、按鈕、文字光標），
	   腳本失效時仍有系統游標可用 */
	html.has-custom-cursor,
	html.has-custom-cursor * {
		cursor: none !important;
	}
</style>

<style>
	/* 流星拖尾畫布：鋪滿視口，畫在游標點之下 */
	.cursor-trail {
		position: fixed;
		inset: 0;
		width: 100vw;
		height: 100vh;
		z-index: 9997;
		pointer-events: none;
	}

	/* 游標本體：主題色圓點（流星頭） */
	.cursor {
		width: 8px;
		height: 8px;
		background-color: var(--color-accent);
		border: 1.5px solid transparent;
		border-radius: 50%;
		position: fixed;
		left: 0;
		top: 0;
		pointer-events: none; /* 絕對必要：讓游標穿透，不阻擋下層點擊 */
		z-index: 9999;
		box-shadow: 0 0 10px rgba(255, 0, 72, 0.55);
		opacity: 0; /* 初始隱藏，偵測到指針移動才顯示 */
		transition:
			opacity 0.3s ease,
			background-color 0.25s ease,
			border-color 0.25s ease;
		will-change: transform;
	}

	/* 模式：懸停可點元素時變成主題色空心圓環 */
	.cursor[data-mode='link'] {
		background-color: transparent;
		border-color: var(--color-accent);
	}

	/* 游標旁的標本標籤：懸停在作品上時顯示動作提示（如 VIEW） */
	.cursor-label {
		position: fixed;
		left: 0;
		top: 0;
		z-index: 9998;
		pointer-events: none;
		padding: 3px 8px;
		background: rgba(248, 249, 250, 0.92);
		box-shadow: 0 2px 12px -4px rgba(26, 26, 26, 0.25);
		color: var(--color-ink);
		opacity: 0;
		transition: opacity 0.25s ease;
		will-change: transform;
	}
</style>

<script>
	// 流星游標：主題色圓點 + 彗尾拖跡（移動時淡出的漸細軌跡），
	// 點擊時迸出一簇火花（短暫的彩色速度線，像流星擦出的碎屑）。
	// 效能：單一 rAF 循環同時驅動點的插值與畫布繪製，全部靜止後自動停機。
	const cursor = document.querySelector('.cursor');
	const label = document.querySelector('.cursor-label');
	const canvas = document.querySelector('.cursor-trail');

	if (
		cursor instanceof HTMLElement &&
		canvas instanceof HTMLCanvasElement &&
		window.matchMedia('(pointer: fine)').matches
	) {
		const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		const ctx = canvas.getContext('2d');
		const accent =
			getComputedStyle(document.documentElement).getPropertyValue('--color-accent').trim() ||
			'#ff0048';
		// 火花色板：主題色 + 玫瑰 / 琥珀 / 淡粉
		const SPARK_COLORS = [accent, '#ffaad4', '#ffbe0b', '#fdc5f5'];

		const dpr = Math.min(window.devicePixelRatio || 1, 2);
		const resize = () => {
			canvas.width = Math.floor(window.innerWidth * dpr);
			canvas.height = Math.floor(window.innerHeight * dpr);
		};
		resize();
		window.addEventListener('resize', resize);

		let x = -100;
		let y = -100;
		let targetX = -100;
		let targetY = -100;
		let scale = 1;
		let targetScale = 1;
		let hoveringLink = false;
		let pressing = false;
		let rafId = 0;
		let visible = false;

		// —— 彗尾：最近軌跡點（帶時間戳，繪製時按年齡漸隱漸細）——
		type TrailPoint = { x: number; y: number; t: number };
		const TRAIL_LIFE = 420; // ms
		let trail: TrailPoint[] = [];

		// —— 點擊火花 ——
		type Spark = {
			x: number;
			y: number;
			vx: number;
			vy: number;
			age: number;
			life: number;
			color: string;
		};
		let sparks: Spark[] = [];
		let lastFrame = 0;

		const spawnBurst = (bx: number, by: number) => {
			const count = 12;
			for (let i = 0; i < count; i++) {
				const ang = (i / count) * Math.PI * 2 + Math.random() * 0.6;
				const speed = 2.2 + Math.random() * 4.2;
				sparks.push({
					x: bx,
					y: by,
					vx: Math.cos(ang) * speed,
					vy: Math.sin(ang) * speed,
					age: 0,
					life: 380 + Math.random() * 320,
					color: SPARK_COLORS[Math.floor(Math.random() * SPARK_COLORS.length)],
				});
			}
		};

		const paint = (now: number, dt: number) => {
			if (!ctx) return false;
			ctx.clearRect(0, 0, canvas.width, canvas.height);
			let busy = false;

			// 彗尾：相鄰軌跡點連成漸細漸隱的光帶
			trail = trail.filter((p) => now - p.t < TRAIL_LIFE);
			if (trail.length > 1) {
				busy = true;
				ctx.lineCap = 'round';
				ctx.shadowColor = accent;
				ctx.shadowBlur = 10 * dpr;
				for (let i = 1; i < trail.length; i++) {
					const a = trail[i - 1];
					const b = trail[i];
					const k = 1 - (now - b.t) / TRAIL_LIFE; // 0 舊 → 1 新
					ctx.strokeStyle = accent;
					ctx.globalAlpha = 0.55 * k * k;
					ctx.lineWidth = (0.5 + 4.5 * k) * dpr;
					ctx.beginPath();
					ctx.moveTo(a.x * dpr, a.y * dpr);
					ctx.lineTo(b.x * dpr, b.y * dpr);
					ctx.stroke();
				}
				ctx.shadowBlur = 0;
				ctx.globalAlpha = 1;
			}

			// 火花：速度線碎屑，帶阻尼與微重力
			if (sparks.length) {
				busy = true;
				const step = dt / 16.7;
				for (const s of sparks) {
					s.age += dt;
					s.x += s.vx * step;
					s.y += s.vy * step;
					s.vx *= 0.94;
					s.vy = s.vy * 0.94 + 0.05 * step;
					const k = 1 - s.age / s.life;
					if (k <= 0) continue;
					ctx.strokeStyle = s.color;
					ctx.globalAlpha = Math.max(0, k);
					ctx.lineWidth = 1.6 * dpr;
					ctx.beginPath();
					ctx.moveTo(s.x * dpr, s.y * dpr);
					ctx.lineTo((s.x - s.vx * 2.4) * dpr, (s.y - s.vy * 2.4) * dpr);
					ctx.stroke();
				}
				ctx.globalAlpha = 1;
				sparks = sparks.filter((s) => s.age < s.life);
			}

			return busy;
		};

		const loop = (now: number) => {
			const dt = lastFrame ? Math.min(48, now - lastFrame) : 16.7;
			lastFrame = now;

			x += (targetX - x) * 0.25;
			y += (targetY - y) * 0.25;
			scale += (targetScale - scale) * 0.18;
			cursor.style.transform = `translate3d(${x - 4}px, ${y - 4}px, 0) scale(${scale.toFixed(3)})`;
			if (label instanceof HTMLElement) {
				label.style.transform = `translate3d(${x + 18}px, ${y + 18}px, 0)`;
			}

			const painting = reduced ? false : paint(now, dt);

			const settled =
				Math.abs(targetX - x) < 0.1 &&
				Math.abs(targetY - y) < 0.1 &&
				Math.abs(targetScale - scale) < 0.01 &&
				!painting;

			if (settled) {
				rafId = 0;
				lastFrame = 0;
			} else {
				rafId = requestAnimationFrame(loop);
			}
		};

		const wake = () => {
			if (!rafId) rafId = requestAnimationFrame(loop);
		};

		const updateScale = () => {
			targetScale = pressing ? 2.2 : hoveringLink ? 1.9 : 1;
			wake();
		};

		window.addEventListener(
			'pointermove',
			(e) => {
				targetX = e.clientX;
				targetY = e.clientY;
				if (!visible) {
					visible = true;
					x = targetX;
					y = targetY;
					document.documentElement.classList.add('has-custom-cursor');
					cursor.style.opacity = '1';
				}
				if (!reduced) trail.push({ x: e.clientX, y: e.clientY, t: performance.now() });
				wake();
			},
			{ passive: true }
		);

		window.addEventListener('pointerdown', (e) => {
			pressing = true;
			updateScale();
			if (!reduced) spawnBurst(e.clientX, e.clientY);
			wake();
		});

		window.addEventListener('pointerup', () => {
			pressing = false;
			updateScale();
		});

		// 懸停在可點擊元素上時：游標放大並切換為空心圓環；
		// 帶 data-cursor-label 的元素會在游標旁顯示動作標籤（如 VIEW / FLIP / DRAG）
		document.addEventListener('mouseover', (e) => {
			const el = e.target instanceof Element ? e.target : null;
			hoveringLink = !!el?.closest('a, button, [role="button"]');
			updateScale();
			cursor.dataset.mode = hoveringLink ? 'link' : 'dot';

			if (label instanceof HTMLElement) {
				const tagged = el?.closest('[data-cursor-label]');
				if (tagged) {
					label.textContent = tagged.getAttribute('data-cursor-label');
					label.style.opacity = '1';
				} else {
					label.style.opacity = '0';
				}
			}
		});
	}
</script>
