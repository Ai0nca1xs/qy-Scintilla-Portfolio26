---
// Hero 背景「以太雲」（Clouds of æther，取自 smlsvnssn 的 CodePen，改為白底版）。
// 三片全屏徑向漸層矩形，各以不同週期緩慢漂移、自轉、呼吸，疊合成流動的彩色雲氣。
// 純 SVG + SMIL 宣告式動畫——無 JS 動畫迴圈、無 canvas、無 rAF，效能極省
// （取代原先的 canvas 光弧 HeroField）。
//
// 白底適配：原作亮色靠「深底發光」；此處對三片矩形用 mix-blend-mode: multiply，
// 讓桃紅／天藍／暖黃在白紙上做「減色混合」（像水彩／油墨暈染）——白處保持純白，
// 交疊處自然加深為乾淨的二次色（桃紅×藍=紫、桃紅×黃=橘、藍×黃=綠）。
// 顏色：桃紅 #ff0048、青 #00aeef、黃 #ffd400；subtle 濃度（低不透明度）。
// 底緣以遮罩漸隱入白，滾動離開自然。
---

<svg
	class="aether-clouds"
	viewBox="0 0 100 100"
	preserveAspectRatio="xMidYMid slice"
	aria-hidden="true"
	data-aether
>
	<defs>
		<radialGradient id="aether-a" cx="50%" cy="50%" fx="10%" fy="50%" r=".5">
			<animate attributeName="fx" dur="34s" values="0%;10%;0%" repeatCount="indefinite" />
			<stop offset="0%" stop-color="#ff0048" stop-opacity="0.29" />
			<stop offset="100%" stop-color="#ff0048" stop-opacity="0" />
		</radialGradient>
		<radialGradient id="aether-b" cx="50%" cy="50%" fx="10%" fy="50%" r=".5">
			<animate attributeName="fx" dur="23.5s" values="0%;10%;0%" repeatCount="indefinite" />
			<stop offset="0%" stop-color="#00aeef" stop-opacity="0.27" />
			<stop offset="100%" stop-color="#00aeef" stop-opacity="0" />
		</radialGradient>
		<radialGradient id="aether-c" cx="50%" cy="50%" fx="50%" fy="50%" r=".5">
			<animate attributeName="fx" dur="21.5s" values="0%;10%;0%" repeatCount="indefinite" />
			<stop offset="0%" stop-color="#ffd400" stop-opacity="0.31" />
			<stop offset="100%" stop-color="#ffd400" stop-opacity="0" />
		</radialGradient>
	</defs>
	<rect x="0" y="0" width="100%" height="100%" fill="url(#aether-a)">
		<animate attributeName="x" dur="20s" values="25%;0%;25%" repeatCount="indefinite" />
		<animate attributeName="y" dur="21s" values="0%;25%;0%" repeatCount="indefinite" />
		<animateTransform
			attributeName="transform"
			type="rotate"
			from="0 50 50"
			to="360 50 50"
			dur="17s"
			repeatCount="indefinite"
		/>
	</rect>
	<rect x="0" y="0" width="100%" height="100%" fill="url(#aether-b)">
		<animate attributeName="x" dur="23s" values="-25%;0%;-25%" repeatCount="indefinite" />
		<animate attributeName="y" dur="24s" values="0%;50%;0%" repeatCount="indefinite" />
		<animateTransform
			attributeName="transform"
			type="rotate"
			from="0 50 50"
			to="360 50 50"
			dur="18s"
			repeatCount="indefinite"
		/>
	</rect>
	<rect x="0" y="0" width="100%" height="100%" fill="url(#aether-c)">
		<animate attributeName="x" dur="25s" values="0%;25%;0%" repeatCount="indefinite" />
		<animate attributeName="y" dur="26s" values="0%;25%;0%" repeatCount="indefinite" />
		<animateTransform
			attributeName="transform"
			type="rotate"
			from="360 50 50"
			to="0 50 50"
			dur="19s"
			repeatCount="indefinite"
		/>
	</rect>
</svg>

<style>
	/* 滿版首屏：向上越過透明 header，寬滿 100vw，無白邊（與原 HeroField 定位一致）*/
	.aether-clouds {
		position: absolute;
		top: calc(var(--header-h) * -1);
		left: 50%;
		transform: translateX(-50%);
		width: 100vw;
		height: calc(100svh + var(--header-h));
		z-index: 0;
		pointer-events: none;
		/* 白底之上：減色混合層自身隔離，確保三片彼此＋白底做乾淨 multiply */
		isolation: isolate;
		/* 下半緣漸隱入白畫布 */
		-webkit-mask-image: linear-gradient(180deg, #000 0%, #000 72%, transparent 100%);
		mask-image: linear-gradient(180deg, #000 0%, #000 72%, transparent 100%);
	}

	/* 三片雲：白紙上的減色暈染 */
	.aether-clouds rect {
		mix-blend-mode: multiply;
	}
</style>

<script>
	// SMIL 不自動遵循「減弱動效」偏好，也不會在離開視口時停機——這裡補上：
	// 減弱動效 → 凍結；離開視口 → 暫停合成，回來續播。皆為一次性呼叫，非動畫迴圈。
	function initAether() {
		const svg = document.querySelector('svg[data-aether]');
		if (!(svg instanceof SVGSVGElement)) return;

		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
			svg.pauseAnimations();
			return;
		}

		const io = new IntersectionObserver(
			([entry]) => {
				if (entry.isIntersecting) svg.unpauseAnimations();
				else svg.pauseAnimations();
			},
			{ threshold: 0 }
		);
		io.observe(svg);

		document.addEventListener('astro:before-swap', () => io.disconnect(), { once: true });
	}

	document.addEventListener('astro:page-load', initAether);
</script>
