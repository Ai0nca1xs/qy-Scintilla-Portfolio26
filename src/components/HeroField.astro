---
// Hero 背景光場：把 OpenProcessing「geometry」母題（多層旋轉漸變平面干涉）的精髓，
// 用單一全屏 WebGL 片元著色器復刻——約 20 層旋轉線性漸變波帶 + 幾團緩慢漂移的柔光，
// 全部在著色器內累加，融合成白底之上的柔和光譜雲氣。比 p5 的 25 個 3D 盒子輕量得多。
// 效能：DPR 上限 1.5、離開視口暫停、減弱動效時只渲染一幀。
---

<canvas class="hero-field" data-hero-field aria-hidden="true"></canvas>

<style>
	/* 滿版出血：突破容器邊距，鋪滿整個視口寬度 */
	.hero-field {
		position: absolute;
		top: 0;
		left: 50%;
		transform: translateX(-50%);
		width: 100vw;
		height: 100%;
		z-index: 0;
		pointer-events: none;
	}
</style>

<script>
	const FRAG = `
precision highp float;
uniform float u_t;
uniform vec2 u_r;
uniform vec2 u_m;

// 站點純色盤（歸一化 RGB）
const vec3 P0 = vec3(0.894, 0.0, 0.486);  // 洋紅
const vec3 P1 = vec3(1.0, 0.361, 0.0);    // 橙
const vec3 P2 = vec3(1.0, 0.835, 0.0);    // 黃
const vec3 P3 = vec3(0.122, 0.235, 1.0);  // 藍
const vec3 P4 = vec3(0.35, 0.75, 0.72);   // 青

vec3 pal(int i) {
	int m = i - (i / 5) * 5;
	if (m == 0) return P0;
	if (m == 1) return P1;
	if (m == 2) return P2;
	if (m == 3) return P3;
	return P4;
}

const float PI = 3.14159265;

void main() {
	vec2 uv = gl_FragCoord.xy / u_r;
	vec2 p = uv - 0.5;
	p.x *= u_r.x / u_r.y;

	// 游標桶形牽引：靠近游標處輕微被拉扯
	vec2 m = u_m - 0.5;
	m.x *= u_r.x / u_r.y;
	p += (m - p) * 0.05 * exp(-length(p - m) * 1.4);

	vec3 tint = vec3(0.0);
	float wsum = 0.0;

	// 20 層旋轉漸變波帶（幾何母題精髓）
	for (int i = 0; i < 20; i++) {
		float fi = float(i);
		float ang = fi * 2.399963 + u_t * 0.03 * (1.0 + 0.3 * sin(fi));
		vec2 dir = vec2(cos(ang), sin(ang));
		float coord = dot(p, dir);
		float freq = 3.0 + mod(fi, 4.0);
		float g = 0.5 + 0.5 * sin(coord * freq * PI + u_t * 0.55 + fi);
		float band = pow(g, 6.0); // 細軟的帶狀分布
		tint += pal(i) * band;
		wsum += band;
	}

	// 4 團緩慢漂移的柔光（呼應原光暈的柔和感）
	for (int j = 0; j < 4; j++) {
		float fj = float(j);
		vec2 c = vec2(sin(u_t * 0.1 + fj * 1.7) * 0.34, cos(u_t * 0.12 + fj * 2.3) * 0.3);
		float b = smoothstep(0.55, 0.0, length(p - c));
		tint += pal(j * 2 + 1) * b * 0.7;
		wsum += b * 0.7;
	}

	tint /= max(wsum, 0.001);
	// 邊緣柔化：向四周淡出，中央略濃，保持通透airy
	float vig = smoothstep(1.2, 0.2, length(p));
	// 整體背景色調強度壓低至約 10–20%，僅作極淡的光譜底氣
	float amt = clamp(wsum * 0.075 * vig, 0.0, 0.18);
	vec3 col = mix(vec3(1.0), tint, amt);
	gl_FragColor = vec4(col, 1.0);
}`;

	const VERT = `attribute vec2 a_pos; void main() { gl_Position = vec4(a_pos, 0.0, 1.0); }`;

	function initHeroField() {
		const canvas = document.querySelector('[data-hero-field]');
		if (!(canvas instanceof HTMLCanvasElement)) return;
		const gl = canvas.getContext('webgl', { antialias: false, alpha: false });
		if (!gl) return;

		const compile = (type: number, src: string) => {
			const s = gl.createShader(type)!;
			gl.shaderSource(s, src);
			gl.compileShader(s);
			return s;
		};
		const program = gl.createProgram()!;
		gl.attachShader(program, compile(gl.VERTEX_SHADER, VERT));
		gl.attachShader(program, compile(gl.FRAGMENT_SHADER, FRAG));
		gl.linkProgram(program);
		if (!gl.getProgramParameter(program, gl.LINK_STATUS)) return;
		gl.useProgram(program);

		const buf = gl.createBuffer();
		gl.bindBuffer(gl.ARRAY_BUFFER, buf);
		gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 3, -1, -1, 3]), gl.STATIC_DRAW);
		const loc = gl.getAttribLocation(program, 'a_pos');
		gl.enableVertexAttribArray(loc);
		gl.vertexAttribPointer(loc, 2, gl.FLOAT, false, 0, 0);

		const uT = gl.getUniformLocation(program, 'u_t');
		const uR = gl.getUniformLocation(program, 'u_r');
		const uM = gl.getUniformLocation(program, 'u_m');

		// 解析度降採樣 + DPR 上限，兼顧清晰與效能
		const dpr = Math.min(window.devicePixelRatio || 1, 1.5) * 0.85;
		const resize = () => {
			canvas.width = Math.max(1, Math.floor(canvas.clientWidth * dpr));
			canvas.height = Math.max(1, Math.floor(canvas.clientHeight * dpr));
			gl.viewport(0, 0, canvas.width, canvas.height);
		};
		resize();
		window.addEventListener('resize', resize);

		let mx = 0.5;
		let my = 0.5;
		window.addEventListener(
			'pointermove',
			(e) => {
				const r = canvas.getBoundingClientRect();
				mx = (e.clientX - r.left) / r.width;
				my = (e.clientY - r.top) / r.height;
			},
			{ passive: true }
		);

		const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		let rafId = 0;
		let visible = true;
		const start = performance.now();

		const draw = () => {
			const t = reduced ? 8 : (performance.now() - start) / 1000;
			gl.uniform1f(uT, t);
			gl.uniform2f(uR, canvas.width, canvas.height);
			gl.uniform2f(uM, mx, my);
			gl.drawArrays(gl.TRIANGLES, 0, 3);
			if (!reduced && visible) rafId = requestAnimationFrame(draw);
		};

		// 離開視口暫停，回到視口續播
		const io = new IntersectionObserver(
			([entry]) => {
				visible = entry.isIntersecting;
				if (visible && !reduced && !rafId) rafId = requestAnimationFrame(draw);
				if (!visible) {
					cancelAnimationFrame(rafId);
					rafId = 0;
				}
			},
			{ threshold: 0 }
		);
		io.observe(canvas);
		draw();

		document.addEventListener(
			'astro:before-swap',
			() => {
				cancelAnimationFrame(rafId);
				io.disconnect();
				window.removeEventListener('resize', resize);
			},
			{ once: true }
		);
	}

	document.addEventListener('astro:page-load', initHeroField);
</script>
