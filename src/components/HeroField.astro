---
// Hero 背景「幾何波簾」：ngsm《geometry》(openprocessing.org/sketch/2616431) 的白底移植版。
// 原作：整幅畫面切成數十條直欄，每欄填一個 repeating-conic 漸層，漸層中心隨
// sin(t − id·φ) 上下波動——欄與欄相位錯開，形成緩慢起伏的彩色波簾。
// 本移植：色彩換成站點熱譜（--heat-*：靛→紫→桃紅→焰橙→琥珀→黃），全部壓低
// 透明度（薄釉感，不搶白底與墨水標題）；波速較原作減半，近乎凝滯的湧動。
// 畫布撐滿首屏（含透明 header），下半緣漸變遮罩隱入白色。
// 效能：半解析度、每 3 幀重繪（~20fps）、離開視口暫停、減弱動效只渲染一幀；
// 不支援 createConicGradient 的舊瀏覽器退化為直欄線性漸層（同一波動邏輯）。
---

<canvas class="hero-field" data-hero-field aria-hidden="true"></canvas>

<style>
	/* 滿版首屏：向上越過透明 header（高度隨斷點變化），寬滿 100vw，無白邊 */
	.hero-field {
		position: absolute;
		top: calc(var(--header-h) * -1);
		left: 50%;
		transform: translateX(-50%);
		width: 100vw;
		height: calc(100svh + var(--header-h));
		z-index: 0;
		pointer-events: none;
		/* 輕柔焦：保留波簾的欄狀結構，只融掉硬邊 */
		filter: blur(6px) saturate(1.1);
		/* 下半緣漸變隱入白色畫布 */
		-webkit-mask-image: linear-gradient(180deg, #000 0%, #000 74%, transparent 100%);
		mask-image: linear-gradient(180deg, #000 0%, #000 74%, transparent 100%);
	}
</style>

<script>
	// 色環：仿原作 Sprague 的「少量實色寬楔」結構（5–6 色、不重複、無透明間隙），
	// 顏色換成站點熱譜＋冷色，全部低透明度（薄釉——她的本地化決定）。
	// 暖冷相接：桃紅 → 焰橙 → 黃 → 青 → 淡藍 → 紫
	const CURTAIN_COLORS = [
		'rgba(255, 0, 72, 0.16)', // 桃紅（主題色）
		'rgba(251, 86, 7, 0.13)', // 焰橙
		'rgba(255, 212, 0, 0.14)', // 黃
		'rgba(0, 174, 239, 0.13)', // 青
		'rgba(155, 205, 255, 0.15)', // 淡藍
		'rgba(131, 56, 236, 0.12)', // 紫
	];

	function initHeroField() {
		const canvas = document.querySelector('[data-hero-field]');
		if (!(canvas instanceof HTMLCanvasElement)) return;
		const ctx = canvas.getContext('2d');
		if (!ctx) return;

		// 半解析度渲染（CSS blur 已負責柔焦）
		const SCALE = 0.5;
		let w = 0;
		let h = 0;

		const resize = () => {
			w = Math.max(1, Math.floor(canvas.clientWidth * SCALE));
			h = Math.max(1, Math.floor(canvas.clientHeight * SCALE));
			canvas.width = w;
			canvas.height = h;
		};
		resize();
		window.addEventListener('resize', resize);

		// 原作 30 欄 / 1000px；此處取 40 欄（她的密度選擇），欄寬隨視口伸縮
		const COLS = 40;
		const supportsConic = typeof ctx.createConicGradient === 'function';

		// 忠實原作 setGradientColorStops 的均勻檔位：stop_i = i/n + 1/(2n)
		// （首尾各留半格平色楔，即原作色輪的自然收邊；不加透明間隔、不重複）
		const addStops = (grad: CanvasGradient) => {
			const n = CURTAIN_COLORS.length;
			for (let i = 0; i < n; i++) {
				grad.addColorStop(i / n + 1 / (2 * n), CURTAIN_COLORS[i]);
			}
		};

		const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		let rafId = 0;
		let visible = true;
		let frameNo = 0;
		const start = performance.now();

		const draw = () => {
			// 波簾湧動極慢，~20fps 足夠——每 3 幀重繪，主線程留給游標與流體
			frameNo++;
			if (!reduced && frameNo % 3 !== 0) {
				if (visible) rafId = requestAnimationFrame(draw);
				return;
			}
			const t = reduced ? 12 : (performance.now() - start) / 1000;
			ctx.clearRect(0, 0, w, h);

			const stepX = w / COLS;
			const amp = h * 0.25; // 波幅：漸層中心的垂直擺程（原作 baseH = height/4）
			const cy = h * 0.48;
			for (let i = 0; i < COLS; i++) {
				// 原作核心：sin(frameCount·0.02 − id·0.1)——欄間相位僅差 0.1，
				// 整幅簾是一個緩慢的大湧浪（速度按她的偏好放慢至 0.2 rad/s）
				const wave = Math.sin(t * 0.2 - i * 0.1);
				const gy = cy + amp * wave;
				const gx = (i + 0.5) * stepX;
				let grad: CanvasGradient;
				if (supportsConic) {
					// 原作 startAngle = gradientY·0.01：±height/4 px → ±2.5 rad，
					// 色輪隨波大幅迴轉——這是原作「旋轉感」的來源（解析度無關化：2.5·wave）
					grad = ctx.createConicGradient(wave * 2.5, gx, gy);
				} else {
					// 舊瀏覽器退化：以波動中心為界的縱向線性漸層
					grad = ctx.createLinearGradient(gx, gy - h * 0.6, gx, gy + h * 0.6);
				}
				addStops(grad);
				ctx.fillStyle = grad;
				ctx.fillRect(i * stepX, 0, stepX + 1, h);
			}

			if (!reduced && visible) rafId = requestAnimationFrame(draw);
		};

		// 離開視口暫停，回到視口續播
		const io = new IntersectionObserver(
			([entry]) => {
				visible = entry.isIntersecting;
				if (visible && !reduced && !rafId) rafId = requestAnimationFrame(draw);
				if (!visible) {
					cancelAnimationFrame(rafId);
					rafId = 0;
				}
			},
			{ threshold: 0 }
		);
		io.observe(canvas);
		draw();

		document.addEventListener(
			'astro:before-swap',
			() => {
				cancelAnimationFrame(rafId);
				io.disconnect();
				window.removeEventListener('resize', resize);
			},
			{ once: true }
		);
	}

	document.addEventListener('astro:page-load', initHeroField);
</script>
