---
// 首頁主體內容，EN / FR 兩個頁面共用，文字全部來自 i18n 詞典。
// 結構：Hero → 01 Profile（含簡版 CV）→ 02 Practice（三列：定位/領域/細分與作品）→ 03 Gallery
import { getCollection } from 'astro:content';
import SplashIntro from '@/components/SplashIntro.astro';
import HeroGlow from '@/components/HeroGlow.astro';
import { localizePath, useTranslations, type Lang } from '@/i18n/utils';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const localePrefix = lang === 'FR' ? 'fr/' : 'en/';
const allEntries = (await getCollection('projects', ({ id }) => id.startsWith(localePrefix))).sort(
	(a, b) => a.data.order - b.data.order
);
const totalCount = allEntries.length;
const year = new Date().getFullYear();

const slugOf = (id: string) => id.replace(/^(en|fr)\//, '');
const projectsFor = (cats: readonly string[]) =>
	allEntries.filter((entry) => cats.includes(entry.data.category));
---

<SplashIntro />

<section class="hero-section">
	<HeroGlow />

	{/* 實驗室取景框：四角的標本檔案 metadata */}
	<div class="hero-corners" aria-hidden="true">
		<span class="metadata corner tl">SCINTILLA — SPECIMEN ARCHIVE</span>
		<span class="metadata corner tr">N° {String(totalCount).padStart(3, '0')} SPECIMENS</span>
		<span class="metadata corner bl">44.84°N — 0.58°W</span>
		<span class="metadata corner br">CAL. {year}</span>
	</div>

	<div class="hero-core">
		<h1 class="hero-title title-calx">SCINTILLA<span class="hero-dot">.</span></h1>
		<div class="metadata hero-meta">{t.home.heroMeta}</div>
	</div>

	<div class="metadata scroll-hint">SCROLL TO DEVELOP ↓</div>
</section>

<section class="concept-intro reveal">
	<p>{t.home.concept}</p>
</section>

<section class="intro-section reveal">
	<span class="section-label">01 / PROFILE</span>
	<div class="intro-grid">
		<p class="lead-text" set:html={t.home.introHtml} />
		<div class="cv-panel">
			<div class="cv-meta">
				{t.home.cvMeta.map((line) => <span class="metadata">{line}</span>)}
			</div>
			<span class="metadata cv-label">EDUCATION</span>
			<ul class="cv-list">
				{t.home.cvEducation.map((line) => <li>{line}</li>)}
			</ul>
			<span class="metadata cv-label">SELECTED EXPERIENCE</span>
			<ul class="cv-list">
				{t.home.cvExperience.map((line) => <li>{line}</li>)}
			</ul>
		</div>
	</div>
</section>

<section class="practice-section reveal">
	<span class="section-label">02 / {t.home.practiceLabel}</span>
	<div class="practice-grid">
		{/* 左列：整個實踐區的「大括號」——個人設計定位 */}
		<div class="practice-intro">
			<p class="practice-lead" set:html={t.home.practiceIntroHtml} />
		</div>

		{/* 中列 + 右列：三大領域及其細分作品 */}
		<div class="practice-domains" data-preview-scope>
			{
				t.home.domains.map((domain) => (
					<div class="domain-block">
						<h2 class="domain-title">
							{domain.cats.map((cat) => (
								<span class="index-swatch" data-cat={cat} aria-hidden="true" />
							))}
							{domain.title}
						</h2>
						<div class="domain-body">
							<p class="domain-blurb">{domain.blurb}</p>
							<ol class="domain-projects">
								{projectsFor(domain.cats).map((entry) => (
									<li>
										<a
											href={localizePath(lang, `/project/${slugOf(entry.id)}`)}
											class="index-row"
											data-slug={slugOf(entry.id)}
											data-cursor-label="VIEW"
										>
											<span class="index-title">{entry.data.title}</span>
											<span class="metadata index-code">
												{entry.data.code} · {entry.data.year}
											</span>
											<span class="index-arrow" aria-hidden="true">
												↗
											</span>
										</a>
									</li>
								))}
							</ol>
							<a
								class="metadata domain-more"
								href={`${localizePath(lang, '/project')}?lens=${domain.lens}`}
							>
								ALL {domain.title} →
							</a>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<section class="gallery-section reveal">
	<span class="section-label">03 / {t.home.galleryLabel}</span>
	<p class="gallery-text">{t.home.galleryText}</p>
	<a href={localizePath(lang, '/gallery')} class="title-calx gallery-cta">{t.home.galleryCta}</a>
</section>

{/* 懸停預覽浮窗：游標移到作品名上時浮出對應的「標本片」 */}
<div class="index-preview" aria-hidden="true">
	{
		allEntries.map((entry) => (
			<figure class="preview-plate" data-plate={slugOf(entry.id)} data-cat={entry.data.category}>
				<span class="metadata plate-code">{entry.data.code}</span>
				<span class="plate-title">{entry.data.title}</span>
			</figure>
		))
	}
</div>

<!-- hero 標題的「液態金屬」SVG 濾鏡（全頁僅此一份定義） -->
<svg style="display: none;" aria-hidden="true">
	<defs>
		<filter id="liquid-filter" x="-25%" y="-25%" width="150%" height="150%">
			<feTurbulence
				type="fractalNoise"
				baseFrequency="0"
				numOctaves="2"
				result="noise"
				id="turbulence"></feTurbulence>
			<feDisplacementMap
				in="SourceGraphic"
				in2="noise"
				scale="0"
				xChannelSelector="R"
				yChannelSelector="G"
				id="displacement"
				result="displaced"></feDisplacementMap>
			<!-- barrel blur：位移後疊加一層可控高斯模糊，形成「熔化/散焦」的餘韻 -->
			<feGaussianBlur in="displaced" stdDeviation="0" id="barrel-blur"></feGaussianBlur>
		</filter>
	</defs>
</svg>

<style>
	/* --- 1. 首屏 (Hero) --- */
	.hero-section {
		position: relative;
		min-height: calc(100svh - 54px);
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		text-align: center;
	}

	/* hero-core / 取景框 / 提示都疊在光暈層之上 */
	.hero-core {
		position: relative;
		z-index: 1;
	}

	.hero-corners .corner {
		position: absolute;
		z-index: 1;
		opacity: 0.4;
	}
	.corner.tl {
		top: 1.4rem;
		left: 0;
	}
	.corner.tr {
		top: 1.4rem;
		right: 0;
	}
	.corner.bl {
		bottom: 1.4rem;
		left: 0;
	}
	.corner.br {
		bottom: 1.4rem;
		right: 0;
	}

	.hero-title {
		font-size: clamp(3.4rem, 14vw, 11rem);
		font-weight: 700;
		line-height: 0.95;
		letter-spacing: 0.02em;
		margin: 0 0 1.2rem;
		/* 濾鏡由 JS 在互動時動態掛載，平時保持零渲染負擔 */
		transition: transform 0.3s var(--ease-oxide);
	}

	.hero-dot {
		color: var(--color-magenta);
	}

	.hero-meta {
		opacity: 0.55;
	}

	.scroll-hint {
		position: absolute;
		z-index: 1;
		bottom: 1.4rem;
		left: 50%;
		transform: translateX(-50%);
		opacity: 0.35;
		animation: hint-pulse 3.2s var(--ease-oxide) infinite;
	}

	@keyframes hint-pulse {
		0%,
		100% {
			opacity: 0.35;
		}
		50% {
			opacity: 0.7;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.scroll-hint {
			animation: none;
		}
	}

	/* --- 2. 概念句 --- */
	.concept-intro {
		max-width: 640px;
		margin: var(--space-xl) auto;
		text-align: center;
	}

	.concept-intro p {
		font-size: 17px;
		line-height: 1.7;
		color: var(--color-ink-soft);
	}

	/* --- 3. Profile：大字自述 + 簡版 CV --- */
	.intro-section {
		margin-bottom: var(--space-xl);
	}

	.intro-grid {
		display: grid;
		grid-template-columns: minmax(0, 7fr) minmax(0, 4fr);
		gap: var(--space-lg);
		align-items: start;
	}

	.lead-text {
		font-size: clamp(1.5rem, 3vw, 2.3rem);
		line-height: 1.45;
		letter-spacing: -0.01em;
		font-weight: 300;
		margin: 0;
	}

	.cv-panel {
		border-top: 1px solid var(--color-line);
		padding-top: 0.8rem;
	}

	.cv-meta {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
		margin-bottom: 1.4rem;
	}

	.cv-label {
		display: block;
		margin-bottom: 0.5rem;
		opacity: 0.45;
	}

	.cv-list {
		list-style: none;
		padding: 0;
		margin: 0 0 1.4rem;
	}

	.cv-list li {
		font-size: 14px;
		line-height: 1.55;
		padding: 0.4rem 0;
		margin: 0;
		border-top: 1px solid var(--color-line);
		opacity: 0.88;
	}

	/* --- 4. Practice：三列融合（定位 / 領域 / 細分與作品）--- */
	.practice-section {
		margin-bottom: var(--space-xl);
	}

	.practice-grid {
		display: grid;
		grid-template-columns: minmax(0, 3fr) minmax(0, 8fr);
		gap: var(--space-lg);
		align-items: start;
	}

	/* 左列「大括號」：吸附跟隨整個區塊 */
	.practice-intro {
		position: sticky;
		top: 90px;
	}

	.practice-lead {
		font-size: clamp(1.15rem, 1.8vw, 1.5rem);
		line-height: 1.5;
		font-weight: 300;
		margin: 0;
		max-width: 34ch;
	}

	.domain-block {
		display: grid;
		grid-template-columns: minmax(0, 3fr) minmax(0, 5fr);
		gap: var(--space-lg);
		align-items: start;
		border-top: 1px solid var(--color-line);
		padding: 1.6rem 0 2.2rem;
	}

	.domain-title {
		position: sticky;
		top: 90px;
		display: flex;
		align-items: center;
		gap: 0.7rem;
		font-size: clamp(1.5rem, 2.4vw, 2.1rem);
		font-weight: 500;
		letter-spacing: -0.01em;
		margin: 0;
	}

	.index-swatch {
		flex-shrink: 0;
		width: 12px;
		height: 12px;
	}
	.index-swatch[data-cat='GRA'] {
		background: var(--cat-gra);
	}
	.index-swatch[data-cat='SCE'] {
		background: var(--cat-sce);
	}
	.index-swatch[data-cat='INS'] {
		background: var(--cat-ins);
	}
	.index-swatch[data-cat='PRD'] {
		background: var(--cat-prd);
	}
	.index-swatch[data-cat='PHO'] {
		background: var(--cat-pho);
	}

	.domain-blurb {
		font-size: 15px;
		line-height: 1.7;
		color: var(--color-ink-soft);
		max-width: 52ch;
		margin-bottom: 1.4rem;
	}

	/* 細分品項：作品行 */
	.domain-projects {
		list-style: none;
		padding: 0;
		margin: 0 0 1rem;
	}

	.index-row {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto auto;
		align-items: baseline;
		gap: 1.2rem;
		padding: 1.1rem 0;
		border-top: 1px solid var(--color-line);
	}

	.index-title {
		font-size: clamp(1.25rem, 2.2vw, 1.7rem);
		font-weight: 400;
		letter-spacing: -0.01em;
		transition: transform 0.45s var(--ease-spring);
	}

	.index-arrow {
		font-size: 15px;
		opacity: 0.4;
		transition:
			transform 0.45s var(--ease-spring),
			opacity 0.3s ease,
			color 0.3s ease;
	}

	/* 底部洋紅細線：hover 時從左向右展開 */
	.index-row::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: -1px;
		height: 1px;
		width: 0%;
		background: var(--color-magenta);
		transition: width 0.6s var(--ease-oxide);
	}

	.index-row:hover {
		opacity: 1;
	}

	.index-row:hover .index-title {
		transform: translateX(0.5rem);
	}

	.index-row:hover .index-arrow {
		opacity: 1;
		color: var(--color-magenta);
		transform: translate(3px, -3px);
	}

	.index-row:hover::after {
		width: 100%;
	}

	.domain-more {
		display: inline-block;
		opacity: 0.55;
		transition:
			opacity 0.3s ease,
			color 0.3s ease;
	}

	.domain-more:hover {
		opacity: 1;
		color: var(--color-magenta);
	}

	/* --- 5. 個人畫廊入口 --- */
	.gallery-section {
		padding-bottom: var(--space-lg);
	}

	.gallery-text {
		font-size: 16px;
		color: var(--color-ink-soft);
		margin-bottom: 1.2rem;
	}

	.gallery-cta {
		font-size: clamp(1.6rem, 4.5vw, 3rem);
		font-weight: 600;
		letter-spacing: 0.01em;
		transition:
			letter-spacing 0.6s var(--ease-oxide),
			color 0.4s var(--ease-oxide);
	}

	.gallery-cta:hover {
		opacity: 1;
		letter-spacing: 0.05em;
		color: var(--color-magenta);
	}

	/* --- 懸停預覽浮窗（標本片）--- */
	.index-preview {
		position: fixed;
		top: 0;
		left: 0;
		width: clamp(230px, 25vw, 340px);
		aspect-ratio: 4 / 3;
		z-index: 9500;
		pointer-events: none;
		opacity: 0;
		transition: opacity 0.35s var(--ease-develop);
		will-change: transform;
	}

	.index-preview.visible {
		opacity: 1;
	}

	.preview-plate {
		position: absolute;
		inset: 0;
		margin: 0;
		padding: 1rem 1.1rem;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		opacity: 0;
		transition: opacity 0.3s ease;
		color: rgba(255, 255, 255, 0.94);
	}

	.preview-plate.active {
		opacity: 1;
	}

	.preview-plate[data-cat='GRA'] {
		background: var(--cat-gra);
	}
	.preview-plate[data-cat='SCE'] {
		background: var(--cat-sce);
	}
	.preview-plate[data-cat='INS'] {
		background: var(--cat-ins);
	}
	.preview-plate[data-cat='PRD'] {
		background: var(--cat-prd);
		color: #1a1a1a;
	}
	.preview-plate[data-cat='PHO'] {
		background: var(--cat-pho);
	}

	.plate-code {
		opacity: 0.8;
		color: inherit;
	}

	.plate-title {
		font-size: 16px;
		font-weight: 500;
		letter-spacing: 0.01em;
	}

	/* --- 響應式 --- */
	@media (max-width: 900px) {
		.intro-grid,
		.practice-grid,
		.domain-block {
			grid-template-columns: 1fr;
		}

		.practice-intro,
		.domain-title {
			position: static;
		}

		.index-row {
			grid-template-columns: minmax(0, 1fr) auto;
		}

		.index-code {
			grid-column: 1;
			order: 3;
		}

		.corner.tr,
		.corner.bl {
			display: none;
		}
	}
</style>

<script>
	// hero 標題的「液態加熱」互動。
	// 效能要點：SVG 濾鏡只在動畫期間掛載到元素上，靜止時完全卸下。
	let animationFrameId: number;

	function initHeroLiquid() {
		const title = document.querySelector('.hero-title') as HTMLElement | null;
		const turbulence = document.querySelector('#turbulence');
		const displacement = document.querySelector('#displacement');
		const barrelBlur = document.querySelector('#barrel-blur');

		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		if (!title || !turbulence || !displacement || !barrelBlur || prefersReducedMotion) return;

		let phase = 0;
		let currentScale = 0;
		let targetScale = 0;

		const animateLiquid = () => {
			phase += 0.05;
			const freqX = 0.015;
			const freqY = 0.015 + Math.sin(phase) * 0.005;
			turbulence.setAttribute('baseFrequency', `${freqX} ${freqY}`);

			currentScale += (targetScale - currentScale) * 0.08;
			displacement.setAttribute('scale', currentScale.toString());
			// barrel blur 隨形變強度連動（位移的 12%），形成散焦餘韻
			barrelBlur.setAttribute('stdDeviation', (currentScale * 0.12).toFixed(3));

			if (targetScale === 0 && currentScale < 0.1) {
				currentScale = 0;
				displacement.setAttribute('scale', '0');
				barrelBlur.setAttribute('stdDeviation', '0');
				title.style.filter = '';
				title.style.willChange = '';
				cancelAnimationFrame(animationFrameId);
				return;
			}

			animationFrameId = requestAnimationFrame(animateLiquid);
		};

		title.addEventListener('mouseenter', () => {
			targetScale = 12;
			title.style.filter = 'url(#liquid-filter)';
			title.style.willChange = 'filter, transform';
			cancelAnimationFrame(animationFrameId);
			animateLiquid();
			title.style.transform = 'scale(1.02) translateY(-2px)';
		});

		title.addEventListener('mouseleave', () => {
			targetScale = 0;
			title.style.transform = '';
		});
	}

	// --- 懸停預覽浮窗：柔性跟隨游標，切換對應的標本片 ---
	let previewRafId = 0;

	function initIndexPreview() {
		if (!window.matchMedia('(pointer: fine)').matches) return;
		const wrap = document.querySelector('.index-preview');
		const scope = document.querySelector('[data-preview-scope]');
		if (!(wrap instanceof HTMLElement) || !scope) return;

		const plates = wrap.querySelectorAll('.preview-plate');
		let x = 0;
		let y = 0;
		let targetX = 0;
		let targetY = 0;
		let shown = false;

		const loop = () => {
			x += (targetX - x) * 0.14;
			y += (targetY - y) * 0.14;
			wrap.style.transform = `translate3d(${x}px, ${y}px, 0)`;
			const settled = Math.abs(targetX - x) < 0.3 && Math.abs(targetY - y) < 0.3;
			previewRafId = settled ? 0 : requestAnimationFrame(loop);
		};

		const wake = () => {
			if (!previewRafId) previewRafId = requestAnimationFrame(loop);
		};

		scope.addEventListener(
			'pointermove',
			(e) => {
				const pe = e as PointerEvent;
				targetX = pe.clientX + 32;
				targetY = pe.clientY - wrap.offsetHeight - 24;
				wake();
			},
			{ passive: true }
		);

		scope.addEventListener('pointerover', (e) => {
			const row = e.target instanceof Element ? e.target.closest('.index-row') : null;
			if (!row) return;
			const slug = row.getAttribute('data-slug');
			plates.forEach((p) => p.classList.toggle('active', p.getAttribute('data-plate') === slug));
			if (!shown) {
				shown = true;
				x = targetX;
				y = targetY;
			}
			wrap.classList.add('visible');
		});

		scope.addEventListener('pointerleave', () => {
			wrap.classList.remove('visible');
			shown = false;
		});
	}

	// --- hero 滾動視差：核心層緩速下沉並淡出，取景框保持不動 ---
	let parallaxRafId = 0;

	function initHeroParallax() {
		const core = document.querySelector('.hero-core');
		if (!(core instanceof HTMLElement)) return;
		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

		const update = () => {
			parallaxRafId = 0;
			const scrolled = window.scrollY;
			const vh = window.innerHeight;
			if (scrolled > vh) return;
			const progress = scrolled / vh;
			core.style.transform = `translateY(${(scrolled * 0.28).toFixed(1)}px)`;
			core.style.opacity = Math.max(0, 1 - progress * 1.15).toFixed(3);
		};

		window.addEventListener(
			'scroll',
			() => {
				if (!parallaxRafId) parallaxRafId = requestAnimationFrame(update);
			},
			{ passive: true }
		);
	}

	document.addEventListener('astro:page-load', () => {
		initHeroLiquid();
		initIndexPreview();
		initHeroParallax();
	});

	document.addEventListener('astro:before-swap', () => {
		cancelAnimationFrame(animationFrameId);
		cancelAnimationFrame(previewRafId);
		cancelAnimationFrame(parallaxRafId);
	});
</script>
