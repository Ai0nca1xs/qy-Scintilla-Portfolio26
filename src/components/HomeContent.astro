---
// 首頁主體內容，EN / FR 兩個頁面共用，文字全部來自 i18n 詞典。
import { getCollection } from 'astro:content';
import { localizePath, useTranslations, type Lang } from '@/i18n/utils';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// 精選作品：從 projects collection 取 featured 條目，按 order 排序，首頁最多展示 5 件
const localePrefix = lang === 'FR' ? 'fr/' : 'en/';
const allEntries = await getCollection('projects', ({ id }) => id.startsWith(localePrefix));
const featured = allEntries
	.filter((entry) => entry.data.featured)
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 5);
const totalCount = allEntries.length;
const year = new Date().getFullYear();
---

<section class="hero-section">
	{/* 實驗室取景框：四角的標本檔案 metadata */}
	<div class="hero-corners" aria-hidden="true">
		<span class="metadata corner tl">SCINTILLA — SPECIMEN ARCHIVE</span>
		<span class="metadata corner tr">N° {String(totalCount).padStart(3, '0')} SPECIMENS</span>
		<span class="metadata corner bl">44.84°N — 0.58°W</span>
		<span class="metadata corner br">CAL. {year}</span>
	</div>

	<div class="hero-core">
		<h1 class="hero-title title-calx">SCINTILLA<span class="hero-dot">.</span></h1>
		<div class="metadata hero-meta">{t.home.heroMeta}</div>
	</div>

	<div class="metadata scroll-hint">SCROLL TO DEVELOP ↓</div>
</section>

<section class="concept-intro reveal">
	<p>{t.home.concept}</p>
</section>

<section class="intro-section reveal">
	<span class="section-label">01 / PROFILE</span>
	<div class="intro-grid">
		<p class="lead-text" set:html={t.home.introHtml} />
		<div class="intro-side metadata">
			<span>BASED IN BORDEAUX, FR</span>
			<span>OPEN TO INTERNSHIPS</span>
			<span>EN · FR · ZH · JP</span>
		</div>
	</div>
</section>

<section class="capabilities-section reveal">
	<span class="section-label">02 / {t.home.capabilitiesLabel}</span>
	<ul class="capabilities-list">
		{
			t.home.capabilities.map((item, i) => (
				<li>
					<span class="metadata cap-num">{String(i + 1).padStart(2, '0')}</span>
					<span class="cap-name">{item}</span>
				</li>
			))
		}
	</ul>
</section>

<section class="work-section reveal">
	<span class="section-label">03 / {t.home.selectedLabel}</span>
	<ol class="project-index">
		{
			featured.map((entry, i) => (
				<li>
					<a
						href={localizePath(lang, `/project/${entry.id.replace(/^(en|fr)\//, '')}`)}
						class="index-row"
						data-slug={entry.id.replace(/^(en|fr)\//, '')}
						data-cursor-label="VIEW"
					>
						<span class="metadata index-num">{String(i + 1).padStart(2, '0')}</span>
						<span class="index-title">
							<span class="index-swatch" data-cat={entry.data.category} aria-hidden="true"></span>
							{entry.data.title}
						</span>
						<span class="metadata index-code">
							{entry.data.code} · {entry.data.year}
						</span>
					</a>
				</li>
			))
		}
	</ol>

	{/* 懸停預覽浮窗：游標移到作品名上時浮出對應的「光譜標本片」，
	    待作品封面圖（cover 字段）就位後即替換為真實縮略圖 */}
	<div class="index-preview" aria-hidden="true">
		{
			featured.map((entry) => (
				<figure
					class="preview-plate"
					data-plate={entry.id.replace(/^(en|fr)\//, '')}
					data-cat={entry.data.category}
				>
					<span class="metadata plate-code">{entry.data.code}</span>
					<span class="plate-title">{entry.data.title}</span>
				</figure>
			))
		}
	</div>
	<a class="metadata archive-link" href={localizePath(lang, '/project')}>
		FULL ARCHIVE ({String(totalCount).padStart(2, '0')}) →
	</a>
</section>

<section class="gallery-section reveal">
	<span class="section-label">04 / {t.home.galleryLabel}</span>
	<p class="gallery-text">{t.home.galleryText}</p>
	<a href={localizePath(lang, '/gallery')} class="title-calx gallery-cta">{t.home.galleryCta}</a>
</section>

<!-- hero 標題的「液態金屬」SVG 濾鏡（全頁僅此一份定義） -->
<svg style="display: none;" aria-hidden="true">
	<defs>
		<filter id="liquid-filter" x="-20%" y="-20%" width="140%" height="140%">
			<feTurbulence
				type="fractalNoise"
				baseFrequency="0"
				numOctaves="2"
				result="noise"
				id="turbulence"></feTurbulence>
			<feDisplacementMap
				in="SourceGraphic"
				in2="noise"
				scale="0"
				xChannelSelector="R"
				yChannelSelector="G"
				id="displacement"></feDisplacementMap>
		</filter>
	</defs>
</svg>

<style>
	/* --- 1. 首屏 (Hero) --- */
	.hero-section {
		position: relative;
		min-height: calc(100svh - 60px); /* 扣除吸頂 header 高度 */
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		text-align: center;
	}

	.hero-corners .corner {
		position: absolute;
		opacity: 0.4;
	}
	.corner.tl {
		top: 1.4rem;
		left: 0;
	}
	.corner.tr {
		top: 1.4rem;
		right: 0;
	}
	.corner.bl {
		bottom: 1.4rem;
		left: 0;
	}
	.corner.br {
		bottom: 1.4rem;
		right: 0;
	}

	.hero-title {
		font-size: clamp(3.2rem, 13vw, 9.5rem);
		font-weight: 700;
		line-height: 0.95;
		letter-spacing: 0.02em;
		margin: 0 0 1.2rem;
		/* 濾鏡由 JS 在互動時動態掛載，平時保持零渲染負擔 */
		transition: transform 0.3s var(--ease-oxide);
	}

	.hero-dot {
		color: var(--color-magenta);
	}

	.hero-meta {
		opacity: 0.55;
	}

	.scroll-hint {
		position: absolute;
		bottom: 1.4rem;
		left: 50%;
		transform: translateX(-50%);
		opacity: 0.35;
		animation: hint-pulse 3.2s var(--ease-oxide) infinite;
	}

	@keyframes hint-pulse {
		0%,
		100% {
			opacity: 0.35;
		}
		50% {
			opacity: 0.7;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.scroll-hint {
			animation: none;
		}
	}

	/* --- 2. 概念句 --- */
	.concept-intro {
		max-width: 560px;
		margin: var(--space-xl) auto;
		text-align: center;
	}

	.concept-intro p {
		font-size: 16px;
		line-height: 1.7;
		color: var(--color-ink-soft);
	}

	/* --- 3. 個人簡介：非對稱編輯網格 --- */
	.intro-section {
		margin-bottom: var(--space-xl);
	}

	.intro-grid {
		display: grid;
		grid-template-columns: minmax(0, 7fr) minmax(0, 3fr);
		gap: var(--space-lg);
		align-items: start;
	}

	.lead-text {
		font-size: clamp(1.4rem, 2.8vw, 2.1rem);
		line-height: 1.45;
		letter-spacing: -0.01em;
		font-weight: 300;
		margin: 0;
	}

	.intro-side {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		padding-top: 0.5rem;
		border-top: 1px solid var(--color-line);
	}

	/* --- 4. 能力清單：滿版髮絲線列表 --- */
	.capabilities-section {
		margin-bottom: var(--space-xl);
	}

	.capabilities-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.capabilities-list li {
		display: flex;
		align-items: baseline;
		gap: 2rem;
		padding: 1.1rem 0;
		margin: 0;
		border-top: 1px solid var(--color-line);
		font-size: 16px;
		transition:
			color 0.4s var(--ease-oxide),
			padding-left 0.4s var(--ease-oxide);
	}

	.capabilities-list li:last-child {
		border-bottom: 1px solid var(--color-line);
	}

	/* 氧化微互動：懸停時文字緩慢偏向銅褐並輕微位移 */
	.capabilities-list li:hover {
		color: var(--color-copper);
		padding-left: 0.6rem;
	}

	.cap-num {
		flex-shrink: 0;
	}

	/* --- 5. 精選作品索引 --- */
	.work-section {
		margin-bottom: var(--space-xl);
	}

	.project-index {
		list-style: none;
		padding: 0;
		margin: 0 0 var(--space-md);
	}

	.index-row {
		position: relative;
		display: grid;
		grid-template-columns: 3.5rem minmax(0, 1fr) auto;
		align-items: baseline;
		gap: 1.5rem;
		padding: 1.4rem 0;
		border-top: 1px solid var(--color-line);
	}

	.project-index li:last-child .index-row {
		border-bottom: 1px solid var(--color-line);
	}

	.index-title {
		display: flex;
		align-items: center;
		gap: 0.9rem;
		font-size: clamp(1.3rem, 3.2vw, 2rem);
		font-weight: 400;
		letter-spacing: -0.01em;
		transition: transform 0.5s var(--ease-oxide);
	}

	/* 分類色籤：每行作品前的小純色方塊 */
	.index-swatch {
		flex-shrink: 0;
		width: 11px;
		height: 11px;
	}
	.index-swatch[data-cat='GRA'] {
		background: var(--cat-gra);
	}
	.index-swatch[data-cat='SCE'] {
		background: var(--cat-sce);
	}
	.index-swatch[data-cat='INS'] {
		background: var(--cat-ins);
	}
	.index-swatch[data-cat='PRD'] {
		background: var(--cat-prd);
	}
	.index-swatch[data-cat='PHO'] {
		background: var(--cat-pho);
	}

	/* 底部洋紅細線：hover 時從左向右展開 */
	.index-row::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: -1px;
		height: 1px;
		width: 0%;
		background: var(--color-magenta);
		transition: width 0.6s var(--ease-oxide);
	}

	.index-row:hover {
		opacity: 1;
	}

	.index-row:hover .index-title {
		transform: translateX(0.6rem);
	}

	.index-row:hover::after {
		width: 100%;
	}

	.archive-link {
		display: inline-block;
		opacity: 0.55;
		transition: opacity 0.3s ease;
	}

	.archive-link:hover {
		opacity: 1;
	}

	/* --- 6. 個人畫廊入口 --- */
	.gallery-section {
		padding-bottom: var(--space-lg);
	}

	.gallery-text {
		font-size: 15px;
		color: var(--color-ink-soft);
		margin-bottom: 1.2rem;
	}

	/* --- 懸停預覽浮窗（光譜標本片）--- */
	.index-preview {
		position: fixed;
		top: 0;
		left: 0;
		width: clamp(220px, 24vw, 320px);
		aspect-ratio: 4 / 3;
		z-index: 9500;
		pointer-events: none;
		opacity: 0;
		transition: opacity 0.35s var(--ease-develop);
		will-change: transform;
	}

	.index-preview.visible {
		opacity: 1;
	}

	.preview-plate {
		position: absolute;
		inset: 0;
		margin: 0;
		padding: 1rem 1.1rem;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		opacity: 0;
		transition: opacity 0.3s ease;
		color: rgba(255, 255, 255, 0.94);
	}

	.preview-plate.active {
		opacity: 1;
	}

	/* 每個分類一個純色（真實封面圖就位前的「標本片」底色） */
	.preview-plate[data-cat='GRA'] {
		background: var(--cat-gra);
	}
	.preview-plate[data-cat='SCE'] {
		background: var(--cat-sce);
	}
	.preview-plate[data-cat='INS'] {
		background: var(--cat-ins);
	}
	.preview-plate[data-cat='PRD'] {
		background: var(--cat-prd);
		color: #1a1a1a;
	}
	.preview-plate[data-cat='PHO'] {
		background: var(--cat-pho);
	}

	.plate-code {
		opacity: 0.8;
		color: inherit;
	}

	.plate-title {
		font-size: 14px;
		font-weight: 500;
		letter-spacing: 0.01em;
	}

	.gallery-cta {
		font-size: clamp(1.5rem, 4.5vw, 2.8rem);
		font-weight: 600;
		letter-spacing: 0.01em;
		transition:
			letter-spacing 0.6s var(--ease-oxide),
			color 0.4s var(--ease-oxide);
	}

	.gallery-cta:hover {
		opacity: 1;
		letter-spacing: 0.05em;
		color: var(--color-magenta);
	}

	/* --- 響應式 --- */
	@media (max-width: 768px) {
		.intro-grid {
			grid-template-columns: 1fr;
		}

		.index-row {
			grid-template-columns: 2.5rem minmax(0, 1fr);
			gap: 0.8rem 1rem;
		}

		.index-code {
			grid-column: 2;
		}

		.corner.tr,
		.corner.bl {
			display: none; /* 手機端只保留對角兩枚，避免擁擠 */
		}
	}
</style>

<script>
	// hero 標題的「液態加熱」互動。
	// 效能要點：SVG 濾鏡只在動畫期間掛載到元素上，靜止時完全卸下，
	// 避免 feTurbulence 常駐渲染層造成的卡頓。
	let animationFrameId: number;

	function initHeroLiquid() {
		const title = document.querySelector('.hero-title') as HTMLElement | null;
		const turbulence = document.querySelector('#turbulence');
		const displacement = document.querySelector('#displacement');

		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		if (!title || !turbulence || !displacement || prefersReducedMotion) return;

		let phase = 0;
		let currentScale = 0; // 當前扭曲強度
		let targetScale = 0; // 目標扭曲強度

		const animateLiquid = () => {
			phase += 0.05;
			const freqX = 0.015;
			const freqY = 0.015 + Math.sin(phase) * 0.005;
			turbulence.setAttribute('baseFrequency', `${freqX} ${freqY}`);

			// 線性插值 (Lerp)：當前值以 8% 的速度緩慢逼近目標值
			currentScale += (targetScale - currentScale) * 0.08;
			displacement.setAttribute('scale', currentScale.toString());

			// 冷卻完成後卸下濾鏡並停止循環，歸還渲染資源
			if (targetScale === 0 && currentScale < 0.1) {
				currentScale = 0;
				displacement.setAttribute('scale', '0');
				title.style.filter = '';
				title.style.willChange = '';
				cancelAnimationFrame(animationFrameId);
				return;
			}

			animationFrameId = requestAnimationFrame(animateLiquid);
		};

		title.addEventListener('mouseenter', () => {
			targetScale = 12; // 加熱
			title.style.filter = 'url(#liquid-filter)';
			title.style.willChange = 'filter, transform';
			cancelAnimationFrame(animationFrameId);
			animateLiquid();
			title.style.transform = 'scale(1.02) translateY(-2px)';
		});

		title.addEventListener('mouseleave', () => {
			targetScale = 0; // 冷卻：Lerp 自動處理緩降，降至閾值後卸下濾鏡
			title.style.transform = '';
		});
	}

	// --- 懸停預覽浮窗：柔性跟隨游標，切換對應的標本片 ---
	let previewRafId = 0;

	function initIndexPreview() {
		if (!window.matchMedia('(pointer: fine)').matches) return;
		const wrap = document.querySelector('.index-preview');
		const list = document.querySelector('.project-index');
		if (!(wrap instanceof HTMLElement) || !list) return;

		const plates = wrap.querySelectorAll('.preview-plate');
		let x = 0;
		let y = 0;
		let targetX = 0;
		let targetY = 0;
		let shown = false;

		const loop = () => {
			x += (targetX - x) * 0.14;
			y += (targetY - y) * 0.14;
			wrap.style.transform = `translate3d(${x}px, ${y}px, 0)`;
			const settled = Math.abs(targetX - x) < 0.3 && Math.abs(targetY - y) < 0.3;
			previewRafId = settled ? 0 : requestAnimationFrame(loop);
		};

		const wake = () => {
			if (!previewRafId) previewRafId = requestAnimationFrame(loop);
		};

		list.addEventListener(
			'pointermove',
			(e) => {
				// 浮窗停靠在游標右上方，避免遮住正在讀的標題
				targetX = e.clientX + 32;
				targetY = e.clientY - wrap.offsetHeight - 24;
				wake();
			},
			{ passive: true }
		);

		list.addEventListener('pointerover', (e) => {
			const row = e.target instanceof Element ? e.target.closest('.index-row') : null;
			if (!row) return;
			const slug = row.getAttribute('data-slug');
			plates.forEach((p) => p.classList.toggle('active', p.getAttribute('data-plate') === slug));
			if (!shown) {
				shown = true;
				x = targetX; // 首次出現直接落位，不做長距離飛行
				y = targetY;
			}
			wrap.classList.add('visible');
		});

		list.addEventListener('pointerleave', () => {
			wrap.classList.remove('visible');
			shown = false;
		});
	}

	// --- hero 滾動視差：核心層以較慢速率下沉並淡出，取景框保持不動 ---
	let parallaxRafId = 0;

	function initHeroParallax() {
		const core = document.querySelector('.hero-core');
		if (!(core instanceof HTMLElement)) return;
		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

		const update = () => {
			parallaxRafId = 0;
			const scrolled = window.scrollY;
			const vh = window.innerHeight;
			if (scrolled > vh) return; // 離開首屏後不再計算
			const progress = scrolled / vh;
			core.style.transform = `translateY(${(scrolled * 0.28).toFixed(1)}px)`;
			core.style.opacity = Math.max(0, 1 - progress * 1.15).toFixed(3);
		};

		window.addEventListener(
			'scroll',
			() => {
				if (!parallaxRafId) parallaxRafId = requestAnimationFrame(update);
			},
			{ passive: true }
		);
	}

	document.addEventListener('astro:page-load', () => {
		initHeroLiquid();
		initIndexPreview();
		initHeroParallax();
	});

	// 換頁前停掉動畫循環，避免殘留的 rAF 引用舊頁面的元素
	document.addEventListener('astro:before-swap', () => {
		cancelAnimationFrame(animationFrameId);
		cancelAnimationFrame(previewRafId);
		cancelAnimationFrame(parallaxRafId);
	});
</script>
