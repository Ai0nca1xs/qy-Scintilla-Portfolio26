---
// 首頁主體內容，EN / FR 兩個頁面共用，文字全部來自 i18n 詞典。
// 結構：Hero（流體墨水標題）→ 概念句 → 01 Profile → 02 Practice（緊湊三列）→ 03 Gallery
import { getCollection } from 'astro:content';
import SplashIntro from '@/components/SplashIntro.astro';
import HeroField from '@/components/HeroField.astro';
import FluidTitle from '@/components/FluidTitle.astro';
import { localizePath, useTranslations, type Lang } from '@/i18n/utils';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const localePrefix = lang === 'FR' ? 'fr/' : 'en/';
const allEntries = (await getCollection('projects', ({ id }) => id.startsWith(localePrefix))).sort(
	(a, b) => a.data.order - b.data.order
);

const slugOf = (id: string) => id.replace(/^(en|fr)\//, '');
const projectsFor = (cats: readonly string[]) =>
	allEntries.filter((entry) => cats.includes(entry.data.category));
---

<SplashIntro />

<section class="hero-section">
	<HeroField />

	{/* 流體墨水標題：畫布鋪滿 hero；標題與 meta 句一同積墨顯影 */}
	<FluidTitle meta={t.home.heroMeta} />

	<div class="metadata scroll-hint">Scroll to develop ↓</div>
</section>

{/* 概念句：引言式 Helvetica Italic，禁止自動換行 */}
<section class="concept-intro">
	<p data-type-shuffle>{t.home.concept}</p>
</section>

<section class="intro-section">
	<span class="section-label">01 / Profile</span>
	<div class="intro-grid">
		<p class="lead-text" data-text-motion set:html={t.home.introHtml} />
		<div class="cv-panel">
			<div class="cv-meta">
				{t.home.cvMeta.map((line) => <span class="metadata">{line}</span>)}
			</div>
			<span class="metadata cv-label">Education</span>
			<ul class="cv-list">
				{t.home.cvEducation.map((line) => <li>{line}</li>)}
			</ul>
			<span class="metadata cv-label">Selected experience</span>
			<ul class="cv-list">
				{t.home.cvExperience.map((line) => <li>{line}</li>)}
			</ul>
		</div>
	</div>
</section>

<section class="practice-section">
	<span class="section-label">02 / {t.home.practiceLabel}</span>
	<div class="practice-grid">
		{/* 左列：緊湊的定位說明 */}
		<div class="practice-intro">
			<p class="practice-lead" set:html={t.home.practiceIntroHtml} />
		</div>

		{/* 中列 + 右列：三大領域及其細分作品 */}
		<div class="practice-domains" data-preview-scope>
			{
				t.home.domains.map((domain) => (
					<div class="domain-block">
						<h2 class="domain-title">{domain.title}</h2>
						<div class="domain-body">
							<p class="domain-blurb" data-type-shuffle>{domain.blurb}</p>
							<ol class="domain-projects">
								{projectsFor(domain.cats).map((entry) => (
									<li>
										<a
											href={localizePath(lang, `/project/${slugOf(entry.id)}`)}
											class="index-row"
											data-slug={slugOf(entry.id)}
											data-cursor-label="VIEW"
										>
											<span class="index-title">{entry.data.title}</span>
											<span class="caption-mono index-code">{entry.data.year}</span>
											<span class="index-arrow" aria-hidden="true">
												↗
											</span>
										</a>
									</li>
								))}
							</ol>
							<a
								class="metadata domain-more"
								href={`${localizePath(lang, '/project')}?lens=${domain.lens}`}
							>
								All {domain.title} →
							</a>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<section class="gallery-section">
	<span class="section-label">03 / {t.home.galleryLabel}</span>
	<p class="gallery-text" data-type-shuffle>{t.home.galleryText}</p>
	<a href={localizePath(lang, '/gallery')} class="title-calx gallery-cta">{t.home.galleryCta}</a>
</section>

{/* 懸停預覽：X 固定於列表右側，遮罩沿 Y 軸跟隨游標展開；圖版左上角寫具體 tag */}
<div class="index-preview" aria-hidden="true">
	<div class="preview-mask" data-preview-mask>
		{
			allEntries.map((entry) => (
				<figure
					class="preview-plate"
					data-plate={slugOf(entry.id)}
					data-cat={entry.data.category}
				>
					<span class="metadata plate-tag">{t.categories[entry.data.category]}</span>
					<span class="plate-title">{entry.data.title}</span>
				</figure>
			))
		}
	</div>
</div>

<style>
	/* --- 1. 首屏 (Hero) --- */
	.hero-section {
		position: relative;
		min-height: calc(100svh - 54px);
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		text-align: center;
	}

	.scroll-hint {
		position: absolute;
		z-index: 1;
		bottom: 1.4rem;
		left: 50%;
		transform: translateX(-50%);
		opacity: 0.35;
		animation: hint-pulse 3.2s var(--ease-oxide) infinite;
	}

	@keyframes hint-pulse {
		0%,
		100% {
			opacity: 0.35;
		}
		50% {
			opacity: 0.7;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.scroll-hint {
			animation: none;
		}
	}

	/* --- 2. 概念句：引言（18px Helvetica Italic），單行不換行 --- */
	.concept-intro {
		margin: var(--space-xl) auto;
		text-align: center;
		overflow: hidden;
	}

	.concept-intro p {
		font-family: var(--font-primary);
		font-style: italic;
		font-weight: 300;
		font-size: clamp(11px, 1.9vw, 18px);
		line-height: 1.5;
		white-space: nowrap;
		color: var(--text-secondary);
	}

	/* --- 3. Profile：自述 + 簡版 CV --- */
	.intro-section {
		margin-bottom: var(--space-xl);
	}

	.intro-grid {
		display: grid;
		grid-template-columns: minmax(0, 7fr) minmax(0, 4fr);
		gap: var(--space-lg);
		align-items: start;
	}

	/* 自述：Helvetica Neue Light，正常字距（修正 Roboto Mono 造成的字距過大）*/
	.lead-text {
		font-family: var(--font-primary);
		font-size: clamp(1.25rem, 2.2vw, 1.75rem);
		line-height: 1.55;
		letter-spacing: 0;
		font-weight: 300;
		margin: 0;
		max-width: 560px;
	}

	.cv-panel {
		padding-top: 0.8rem;
	}

	.cv-meta {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
		margin-bottom: 1.4rem;
	}

	.cv-label {
		display: block;
		margin-bottom: 0.5rem;
		opacity: 0.45;
	}

	.cv-list {
		list-style: none;
		padding: 0;
		margin: 0 0 1.4rem;
		max-width: 480px;
	}

	.cv-list li {
		padding: 0.3rem 0;
		margin: 0;
		opacity: 0.88;
	}

	/* --- 4. Practice：緊湊三列 --- */
	.practice-section {
		margin-bottom: var(--space-xl);
	}

	.practice-grid {
		display: grid;
		grid-template-columns: minmax(0, 2fr) minmax(0, 9fr);
		gap: calc(var(--space-lg) * 1.5);
		align-items: start;
	}

	/* 左列：緊湊定位說明（12px 內文級）*/
	.practice-intro {
		position: sticky;
		top: 90px;
	}

	.practice-lead {
		font-size: 12px;
		line-height: 1.8;
		font-weight: 300;
		color: var(--text-secondary);
		margin: 0;
		max-width: 26ch;
	}

	.domain-block {
		display: grid;
		grid-template-columns: minmax(0, 2fr) minmax(0, 6fr);
		gap: calc(var(--space-lg) * 1.25);
		align-items: start;
		padding: 1.6rem 0 2.4rem;
	}

	/* 首個領域塊與左列頂對齊 */
	.domain-block:first-child {
		padding-top: 0;
	}

	/* 領域標題：字號縮小、無色塊，懸浮微位移 */
	.domain-title {
		position: sticky;
		top: 90px;
		font-size: 18px;
		font-weight: 700;
		letter-spacing: 0;
		margin: 0;
		transition: transform 0.4s var(--ease-develop);
	}

	.domain-title:hover {
		transform: translateX(6px);
	}

	.domain-blurb {
		color: var(--text-secondary);
		max-width: 400px;
		margin-bottom: 1.6rem;
	}

	/* 細分品項：作品行 */
	.domain-projects {
		list-style: none;
		padding: 0;
		margin: 0 0 1.2rem;
	}

	.index-row {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto auto;
		align-items: baseline;
		gap: 1.2rem;
		padding: 0.8rem 0;
	}

	.index-title {
		font-family: var(--font-title);
		font-size: 18px;
		font-weight: 500;
		letter-spacing: -0.01em;
		transition: transform 0.45s var(--ease-spring);
	}

	.index-arrow {
		font-size: 12px;
		opacity: 0.4;
		transition:
			transform 0.45s var(--ease-spring),
			opacity 0.3s ease,
			color 0.3s ease;
	}

	/* 底部強調細線：hover 時從左向右展開（互動反饋，非結構線）*/
	.index-row::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: -1px;
		height: 1px;
		width: 0%;
		background: var(--color-accent);
		transition: width 0.6s var(--ease-oxide);
	}

	.index-row:hover {
		opacity: 1;
	}

	.index-row:hover .index-title {
		transform: translateX(0.5rem);
	}

	.index-row:hover .index-arrow {
		opacity: 1;
		color: var(--color-accent);
		transform: translate(3px, -3px);
	}

	.index-row:hover::after {
		width: 100%;
	}

	.domain-more {
		display: inline-block;
		opacity: 0.55;
		transition:
			opacity 0.3s ease,
			color 0.3s ease;
	}

	.domain-more:hover {
		opacity: 1;
		color: var(--color-accent);
	}

	/* --- 5. 個人畫廊入口 --- */
	.gallery-section {
		padding-bottom: var(--space-lg);
	}

	.gallery-text {
		color: var(--text-secondary);
		margin-bottom: 1.2rem;
	}

	.gallery-cta {
		font-family: var(--font-title);
		font-size: clamp(1.6rem, 4.5vw, 3rem);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: -0.02em;
		transition:
			letter-spacing 0.6s var(--ease-oxide),
			color 0.4s var(--ease-oxide);
	}

	.gallery-cta:hover {
		opacity: 1;
		letter-spacing: 0.02em;
		color: var(--color-accent);
	}

	/* --- 懸停預覽：X 固定、Y 軸跟隨游標的遮罩圖版 --- */
	.index-preview {
		position: fixed;
		top: 0;
		right: calc(var(--gutter) + 4vw);
		width: clamp(220px, 24vw, 320px);
		aspect-ratio: 4 / 3;
		z-index: 9500;
		pointer-events: none;
		will-change: transform;
	}

	/* 遮罩：出現時由中縫向上下展開 */
	.preview-mask {
		position: absolute;
		inset: 0;
		overflow: hidden;
		clip-path: inset(48% 0 48% 0);
		opacity: 0;
		transition:
			clip-path 0.55s var(--ease-develop),
			opacity 0.3s ease;
	}

	.index-preview.visible .preview-mask {
		clip-path: inset(0 0 0 0);
		opacity: 1;
	}

	.preview-plate {
		position: absolute;
		inset: 0;
		margin: 0;
		padding: 1rem 1.1rem;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		opacity: 0;
		transition: opacity 0.3s ease;
		color: rgba(255, 255, 255, 0.94);
		will-change: transform;
	}

	.preview-plate.active {
		opacity: 1;
	}

	.preview-plate[data-cat='GRA'] {
		background: var(--cat-gra);
	}
	.preview-plate[data-cat='SCE'] {
		background: var(--cat-sce);
	}
	.preview-plate[data-cat='INS'] {
		background: var(--cat-ins);
	}
	.preview-plate[data-cat='PRD'] {
		background: var(--cat-prd);
		color: #1a1a1a;
	}
	.preview-plate[data-cat='PHO'] {
		background: var(--cat-pho);
	}

	/* 左上角具體 tag（Photographie / Installation …），非編碼 */
	.plate-tag {
		opacity: 0.85;
		color: inherit;
	}

	.plate-title {
		font-family: var(--font-title);
		font-size: 14px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.02em;
	}

	/* --- 響應式 --- */
	@media (max-width: 900px) {
		.intro-grid,
		.practice-grid,
		.domain-block {
			grid-template-columns: 1fr;
			gap: var(--space-md);
		}

		.practice-intro,
		.domain-title {
			position: static;
		}

		.index-row {
			grid-template-columns: minmax(0, 1fr) auto;
		}

		.index-code {
			grid-column: 1;
			order: 3;
		}
	}
</style>

<script>
	// --- 懸停預覽：X 固定，遮罩沿 Y 軸跟隨游標；圖版在遮罩內做輕微反向漂移 ---
	let previewRafId = 0;

	function initIndexPreview() {
		if (!window.matchMedia('(pointer: fine)').matches) return;
		const wrap = document.querySelector('.index-preview');
		const scope = document.querySelector('[data-preview-scope]');
		if (!(wrap instanceof HTMLElement) || !scope) return;

		const plates = wrap.querySelectorAll<HTMLElement>('.preview-plate');
		let y = 0;
		let targetY = 0;
		let shown = false;
		let activePlate: HTMLElement | null = null;

		const loop = () => {
			const dy = targetY - y;
			y += dy * 0.12;
			wrap.style.transform = `translate3d(0, ${y.toFixed(1)}px, 0)`;
			// 圖版在遮罩內部的反向漂移：跟隨速度差，形成「圖片在窗口裡滑動」的層次
			if (activePlate) {
				const drift = Math.max(-28, Math.min(28, dy * 0.3));
				activePlate.style.transform = `translate3d(0, ${drift.toFixed(1)}px, 0) scale(1.06)`;
			}
			previewRafId = Math.abs(dy) > 0.3 ? requestAnimationFrame(loop) : 0;
		};

		const wake = () => {
			if (!previewRafId) previewRafId = requestAnimationFrame(loop);
		};

		scope.addEventListener(
			'pointermove',
			(e) => {
				const pe = e as PointerEvent;
				targetY = pe.clientY - wrap.offsetHeight / 2;
				wake();
			},
			{ passive: true }
		);

		scope.addEventListener('pointerover', (e) => {
			const row = e.target instanceof Element ? e.target.closest('.index-row') : null;
			if (!row) return;
			const slug = row.getAttribute('data-slug');
			plates.forEach((p) => {
				const on = p.getAttribute('data-plate') === slug;
				p.classList.toggle('active', on);
				if (on) activePlate = p;
			});
			if (!shown) {
				shown = true;
				y = targetY; // 首次出現直接就位，避免長距離滑入
				wrap.style.transform = `translate3d(0, ${y.toFixed(1)}px, 0)`;
			}
			wrap.classList.add('visible');
		});

		scope.addEventListener('pointerleave', () => {
			wrap.classList.remove('visible');
			shown = false;
		});
	}

	// --- hero 滾動視差：流體墨水舞台緩速下沉並淡出 ---
	let parallaxRafId = 0;

	function initHeroParallax() {
		const stage = document.querySelector('.fluid-stage');
		if (!(stage instanceof HTMLElement)) return;
		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

		const update = () => {
			parallaxRafId = 0;
			const scrolled = window.scrollY;
			const vh = window.innerHeight;
			if (scrolled > vh) return;
			const progress = scrolled / vh;
			stage.style.transform = `translateY(${(scrolled * 0.28).toFixed(1)}px)`;
			stage.style.opacity = Math.max(0, 1 - progress * 1.15).toFixed(3);
		};

		window.addEventListener(
			'scroll',
			() => {
				if (!parallaxRafId) parallaxRafId = requestAnimationFrame(update);
			},
			{ passive: true }
		);
	}

	document.addEventListener('astro:page-load', () => {
		initIndexPreview();
		initHeroParallax();
	});

	document.addEventListener('astro:before-swap', () => {
		cancelAnimationFrame(previewRafId);
		cancelAnimationFrame(parallaxRafId);
	});
</script>
